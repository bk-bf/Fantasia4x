  // ═══════════════════════════════════════════════════════════════════════════
  // PRODUCTION-CHAIN-II §M — crystal nodes (typed) + ancient-wood groves
  // ═══════════════════════════════════════════════════════════════════════════
  // Crystal nodes — one per mineral (amethyst is the `amethyst_node` in the mining section above). Each
  // mostly yields its NORMAL crystal (1–2) plus an occasional MAGIC-INFUSED crystal (0–1). Rarity
  // comes from the sparse spawn + the 0-floor infused roll, not from the uniform min/max engine.
  // All share the `crystal_formation` render subterrain; mined with a tier-2 pick. They deliberately
  // do NOT spawn on `mineral_deposit`, so they stay out of the ore/coal/salt vein pool.
  {
    "id": "ruby_node", "displayName": "Ruby Crystals", "subterrain": "crystal_formation", "walkable": false,
    "charSpans": [ {"sheet": "tiles", "from": 48, "to": 55} ], "fg": [0.78, 0.12, 0.23], "bg": [0.1, 0.04, 0.05], "color": "#C81E3A",
    "glow": {"color": [0.85, 0.22, 0.32], "radius": 1.8, "intensity": 0.08, "flicker": false},
    "spawn": {"subterrains": {"cave": 0.0025, "rocky": 0.0025, "cliff": 0.002}},
    "nodeAmountRange": [1, 3], "designationTypes": ["harvest"],
    "interaction": {
