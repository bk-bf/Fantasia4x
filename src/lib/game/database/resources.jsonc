  // ─────────────────────────────────────────────────────────────────────────
  // MINING — SURFACE DEPOSITS
  // All require a mining tool. Found in rocky and mountain terrain.
  // ─────────────────────────────────────────────────────────────────────────
  // Common surface rock — most accessible stone source. Chance of bonus flint.
  {
    "id"              : "stone_outcrop",
    "roofSupport"     : true,
    "displayName"     : "Stone Outcrop",
    "subterrain"      : "rocky",
    "walkable"        : false,
    "blocksSight"     : true,
    "charSpans"       : [ {"sheet": "mshock", "tile": "t_rock_unconnected"} ],
    "fg"              : "#9e855e",
    "bg"              : "#1c140a",
    "spawn"           : {
      "subterrains": {"cave": 0.07, "dirt": 0.015, "savanna": 0.02, "grass": 0.01}
    },
    "nodeAmountRange" : [5, 10],
    "designationTypes": ["harvest"],
    // ADR-009 bootstrap: surface stone is hand-SCAVENGED — no tool required (toolRequirement null),
    // so a fresh colony can gather the small_stone / flint primitives its first tools need before
    // it has any tools. Deeper ore (coal, clay deposits) stays pick-gated. Mining skill still
    // boosts yield; with no toolRequirement the harvest is also exempt from R4 tool gating.
    "interaction"     : {
      "action"         : "scavenge",
      "workCategory"   : "mining",
      "workAmount"     : 18,
      "toolRequirement": null,
      "yields"         : [
        {"itemId": "small_stone", "min": 5, "max": 10, "skillId": "mining", "skillMultiplier": 0.2},
        {"itemId": "granite", "min": 0, "max": 5, "skillId": "mining", "skillMultiplier": 0.15},  // chance only: min 0
        {"itemId": "limestone", "min": 0, "max": 2, "skillId": "mining", "skillMultiplier": 0.1},  // chance only: min 0
        {"itemId": "flint_shard", "min": 0, "max": 2, "skillId": "mining", "skillMultiplier": 0.1} // chance only: min 0
      ]
    }
  },
  // ─────────────────────────────────────────────────────────────────────────
  // FORAGING — PLANTS
  // ─────────────────────────────────────────────────────────────────────────
  // Colourful herbaceous patches — primary herb source in open biomes.
