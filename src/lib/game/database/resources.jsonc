// resources.jsonc — Harvestable world resource node definitions.
//
// Schema:
//   id               — unique resource key
//   displayName      — label shown in UI
//   objectSubType    — render category (can align with a subterrain key for visual consistency)
//   charSpans        — glyph source: [{sheet,from,to}] range | [{sheet,id}] single tile | [{literal}] char
//   fg / bg          — [r, g, b] render colours (0–1)
//   color            — hex colour for UI elements
//   spawn.subterrains  — map of subterrain id → per-tile spawn probability (0–1)
//   nodeAmountRange  — [min, max] nodes per cluster when the tile is chosen for spawning
//   designationTypes — which zone types ("harvest" | "forage" | "scavenge") can queue jobs here
//   interaction:
//     action           — verb shown in job queue display
//     workCategory     — skill domain: foraging | woodcutting | mining
//     workAmount       — total work-points to complete this interaction, authored DIRECTLY (1:1,
//                        like a building's `workAmount` in buildings.jsonc — no hidden multiplier).
//                        At the base rate (1 pt/sec, speed 1) it takes `workAmount` sim-seconds,
//                        i.e. ≈ workAmount × 4.8 in-game minutes (a day = 300 sim-sec = 1440 in-game
//                        min). Stats/tools/skills scale the effective rate via getWorkModifiers.
//     toolRequirement  — null = bare hands allowed | {workType, minTier} = tool required
//     yields[]:
//       skillMultiplier  — bonus items granted per level of skillId
//       regrowthTurns    — turns until this yield refills on a persistent node
//       _TODO            — design placeholder; item or production chain not yet implemented
//     persistent       — true: node survives harvest (regrows); absent: node is consumed
//     harvestDepletes  — true: removes only this yield; the node itself stays
[
  // ─────────────────────────────────────────────────────────────────────────
  // PRODUCTION-CHAIN-II §M — ANCIENT-WOOD GROVES (listed FIRST on purpose)
  // ─────────────────────────────────────────────────────────────────────────
  // Pass-1 scatter is first-match-wins in array order (ResourceGeneratorService): the first def
  // whose roll succeeds on a tile claims it and breaks. The common trees + grass patches that
  // follow are FAR more probable, so a grove listed after them on a contested grassy subtype
  // (grass/deep_grass/tall_grass) almost never gets rolled — that starved moonwood to ~1/15th of
  // its intended rate. Listing the (very low-probability) groves FIRST gives each species a fair,
  // independent shot, so all four spawn reliably. Probabilities are tuned for ~10–15 of each per
  // 240×160 map — uncommon and worth seeking, but reliably findable.
  {
    "id": "heartwood_grove", "displayName": "Heartwood Tree", "subterrain": "tree", "walkable": false,
    "charSpans": [ {"sheet": "plants", "from": 0, "to": 71} ], "fg": [0.48, 0.29, 0.42], "bg": [0.08, 0.05, 0.07], "color": "#7A4B6B",
    "glow": {"color": [0.80, 0.46, 0.94], "radius": 2.6, "intensity": 0.52, "flicker": false},
    "spawn": {"subterrains": {"deep_grass": 0.0014, "grass": 0.0006, "dirt": 0.0003}},
    "nodeAmountRange": [2, 4], "designationTypes": ["woodcut", "forage"],
    "interaction": {
      "designationType": "woodcut", "action": "woodcut", "workCategory": "woodcutting", "workAmount": 18, "toolRequirement": {"workType": "woodcutting", "minTier": 2},
      "yields": [
        {"itemId": "heartwood_log", "min": 2, "max": 4, "skillId": "woodcutting", "skillMultiplier": 0.2, "regrowthTurns": 6000},
        {"itemId": "branch", "min": 2, "max": 4, "skillId": "woodcutting", "skillMultiplier": 0.15, "regrowthTurns": 4200},
        {"itemId": "bark", "min": 1, "max": 2, "skillId": "woodcutting", "skillMultiplier": 0.1, "regrowthTurns": 1500}
      ],
      "persistent": true, "harvestDepletes": true
    }
  },
  {
