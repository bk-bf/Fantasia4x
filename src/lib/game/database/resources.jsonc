  // ─────────────────────────────────────────────────────────────────────────
  // LAIRS / NESTS — `lair: true`; rare, listed first. Each placed tile seeds one bound pack of the
  // creature whose `lair` (creatures.jsonc) matches this id. DESTROY razes the den via the harvest
  // path (non-persistent node).
  // ─────────────────────────────────────────────────────────────────────────
  {
    "id"              : "wolf_den",
    "displayName"     : "Wolf Den",
    "subterrain"      : "dirt",
    "walkable"        : true,
    "lair"            : true,
    "lairAttractors"  : ["frostheart_pine"],
    "particleEffect"  : "flies",
    "charSpans"       : [ {"sheet": "crops", "id": 83} ],
    "fg"              : "#808799",
    "bg"              : "#17120a",
    // Base plains/forest scatter HALVED (§3b): frost-pine guardians now den wolves near the mountains, so
    // random forest/plains dens are rarer to keep total lairs from over-inflating (see placeLairGuardians).
    "spawn"           : {
      "subterrains": {"grass": 0.00003, "deep_grass": 0.000045, "tall_grass": 0.000035, "dirt": 0.00003}
    },
    "nodeAmountRange" : [1, 1],
