  // ─── EVOLUTION: the two orthogonal chains whose product derives `type` above ───
  //   <chain>.default       — starting / fallback state id.
  //   <chain>.durationRange — [min,max] ticks a state holds before it's re-rolled.
  //   transitions[]         — weighted neighbours: { to, chance } fixed weight; { to, seasonPrecip }
  //                           pulls the season's precipitation as the weight; seasons:[...] gates by
  //                           season; the leftover weight (1 − Σ) is the chance the state persists.
  //                           `phase` gates a branch to one travel direction of the precip ladder
  //                           (rising vs. falling).
  //   wind.bands            — the 0–1 ambient-wind scalar's range per wind level; the scalar
  //                           random-walks INSIDE its level's band, so the readout always matches the
  //                           level (and thus the derived type).
  //   ladders               — ordered rungs used by the storm-corner step-down (calming both axes).
  //   stormCorner           — derived types that, once reached, break next roll: both chains step one
  //                           rung toward calm (the front passes, leaving stiller, clearer skies).
  //   grid                  — (precip × wind) → display type id. "$season_windy" expands to the active
  //                           season's windy variant (spring_windy / … / winter_windy).
  "precip": {
    "default"      : "dry",
    "durationRange": [50, 400],
    "states"       : [
      {
        "id"         : "dry",
        "transitions": [
          // Precipitation ONSET happens in every season (weighted by that season's `precipitation`);
          // whether it FALLS as rain or snow is decided by temperature at derive time (deriveWeatherType),
          // not gated here — so a sub-0 spring night snows and a winter thaw rains. heat_wave stays summer.
          { "to": "drizzle",   "seasonPrecip": true },
          { "to": "heat_wave", "chance": 0.08, "seasons": ["summer"] },
          { "to": "fog",       "chance": 0.05 }
        ]
      },
      {
        "id"         : "drizzle",
        "transitions": [
          // Building UP from dry: can still develop into rain or simply linger/clear.
          { "to": "rain",       "chance": 0.3,  "phase": "rising" },
          { "to": "dry",        "chance": 0.15, "phase": "rising" },
          { "to": "fog",        "chance": 0.08, "phase": "rising" },
          { "to": "foggy_rain", "chance": 0.08, "phase": "rising" },
          // Easing DOWN from rain: the front is passing — strongly clears, slight chance to relapse.
          { "to": "dry",        "chance": 0.65, "phase": "falling" },
          { "to": "rain",       "chance": 0.35, "phase": "falling" }
        ]
      },
      {
        "id"         : "rain",
        "transitions": [
          // ~60% eases off (35 drizzle / 25 dry), ~25% intensifies, leftover persists.
          { "to": "drizzle",    "chance": 0.35 },
          { "to": "dry",        "chance": 0.25 },
          { "to": "heavy_rain", "chance": 0.25 }
        ]
      },
      {
        "id"         : "heavy_rain",
        "transitions": [
          // Eases toward drizzle/dry; the leftover ~25% stays heavy. (No storm here — storm is the
          // heavy_rain × gale corner, decided by the wind chain.)
          { "to": "drizzle", "chance": 0.35 },
          { "to": "dry",     "chance": 0.25 },
          { "to": "rain",    "chance": 0.15 }
        ]
      },
      {
        "id"         : "snow",
        "transitions": [
          { "to": "dry", "chance": 0.22 },
          { "to": "fog", "chance": 0.08 }
        ]
      },
      {
        "id"         : "fog",
        "transitions": [
          { "to": "dry",        "chance": 0.35 },
          { "to": "foggy_rain", "chance": 0.12 },
          { "to": "drizzle",    "chance": 0.1 },
          { "to": "rain",       "chance": 0.06 }
        ]
      },
      {
        "id"         : "foggy_rain",
        "transitions": [
          { "to": "fog",     "chance": 0.2 },
          { "to": "rain",    "chance": 0.2 },
          { "to": "drizzle", "chance": 0.15 },
          { "to": "dry",     "chance": 0.1 }
        ]
      },
      {
        "id"         : "heat_wave",
        "transitions": [
          { "to": "dry", "chance": 0.4 }
        ]
      }
    ]
  },

  "wind": {
    "default"      : "calm",
    "durationRange": [50, 400],
    "bands"        : {
      "calm"  : [0.0,  0.3],
      "breezy": [0.25, 0.5],
      "windy" : [0.5,  0.72],
      "gale"  : [0.72, 1.0]
    },
    "states": [
      {
        "id"         : "calm",
        "transitions": [
          { "to": "breezy", "chance": 0.25 }
        ]
      },
      {
        "id"         : "breezy",
        "transitions": [
          { "to": "calm",  "chance": 0.3 },
          { "to": "windy", "chance": 0.2 }
        ]
      },
      {
        "id"         : "windy",
        "transitions": [
          { "to": "breezy", "chance": 0.35 },
          { "to": "gale",   "chance": 0.12 },
          { "to": "calm",   "chance": 0.1 }
        ]
      },
      {
        "id"         : "gale",
        "transitions": [
          // Symmetric to the rain descent: a gale spends itself back toward calm.
          { "to": "windy",  "chance": 0.45 },
          { "to": "breezy", "chance": 0.25 },
          { "to": "calm",   "chance": 0.1 }
        ]
      }
    ]
  },

  "ladders": {
    "precip": ["dry", "drizzle", "rain", "heavy_rain"],
    "wind"  : ["calm", "breezy", "windy", "gale"]
  },

  "stormCorner": ["storm", "blizzard"],

  "grid": {
    "dry"       : { "calm": "clear",      "breezy": "clear",      "windy": "$season_windy", "gale": "gale" },
    "drizzle"   : { "calm": "drizzle",    "breezy": "drizzle",    "windy": "drizzle",       "gale": "windy_rain" },
    "rain"      : { "calm": "rain",       "breezy": "rain",       "windy": "windy_rain",    "gale": "storm" },
    "heavy_rain": { "calm": "heavy_rain", "breezy": "heavy_rain", "windy": "windy_rain",    "gale": "storm" },
    "snow"      : { "calm": "snow",       "breezy": "snow",       "windy": "winter_windy",  "gale": "blizzard" },
    "fog"       : { "calm": "fog",        "breezy": "fog",        "windy": "fog",           "gale": "gale" },
    "foggy_rain": { "calm": "foggy_rain", "breezy": "foggy_rain", "windy": "foggy_rain",    "gale": "windy_rain" },
    "heat_wave" : { "calm": "heat_wave",  "breezy": "heat_wave",  "windy": "$season_windy", "gale": "gale" }
  }
}
