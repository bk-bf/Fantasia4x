  // ═══════════════════════════════════════════════════════════════════════════
  // PRODUCTION-CHAIN-II §F — Compost (passive): rot + hay → compost, the soil-gating amendment
  // ═══════════════════════════════════════════════════════════════════════════
  // Passive bin (no pawn job — ADR-016): pawns haul the inputs, the bin rots them down over ~days.
  // Any spoiled organic matter works (inputAlternatives), always with hay as the carbon bulk.
  {
    "id"               : "make_compost",
    "station"          : "compost_bin",
    "passive"          : true,
    "inputs"           : {"rotten_food": 3, "hay": 5},
    "inputAlternatives": [
      {"rotten_meat": 3, "hay": 5                                       },
      {                  "hay": 5, "rotten_carcass": 1                  },
      {                  "hay": 5,                      "rotten_hide": 2}
    ],
    "outputs"          : {"compost": 2},
    "workAmount"       : 48,
    "toolTierRequired" : 0
  },
  // Post-processing step (HSK depth): raw compost is concentrated + aged into potent fertiliser. 3:1 —
  // fertiliser is the expensive amendment the complex soils (loam→terra preta) are built from.
  {
    "id"              : "make_fertiliser",
    "station"         : "compost_bin",
    "passive"         : true,
    "inputs"          : {"compost": 3},
    "outputs"         : {"fertiliser": 1},
    "workAmount"      : 60,
    "toolTierRequired": 0
  },
  // ── PRODUCTION-CHAIN-II §F8 — milling, baking, brewing ───────────────────────────────────────
  // MILL (quern): any grain (wheat / rye / foraged wild oats) → flour. ~3 grain : 2 flour after the bran
  // is sifted out. Category-slotted so every grain mills, and a new grain is wired in automatically.
  {
    "id"               : "mill_flour",
    "station"          : "quern",
    "inputs"           : {"category:grain": 3},
    "outputs"          : {"flour": 2},
    "workAmount"       : 8,
    "toolTierRequired" : 0
  },
  // BAKE (oven): flour + water → bread; flour + meat (+ veg) → pies. A whole loaf takes a real sack of
  // flour (6) — ~9 grain in total, so cooking roughly CONSERVES the grain's food energy (a loaf ≈ the
  // grain that went in) rather than conjuring calories; its value is being safe, digestible and filling.
  {
    "id"              : "bake_bread",
    "station"         : "oven",
    "inputs"          : {"flour": 6, "water": 1},
    "outputs"         : {"bread": 1},
    "workAmount"      : 18,
    "toolTierRequired": 0
  },
  // PIE (oven): an upgrade over bread — the flour gate makes even a simple pie a higher-tier good. The
  // filling is a free pick from meat/fish/veg/fruit, so a pie names itself ("Apple Pie", "Venison & Onion
  // Pie"). Tiers add fillings (1 → 2 → 3 distinct) + flour, climbing the meal buff (nourished → fortified).
  // Fruit fillings make a sweet pie; meat/veg a savoury one — same recipe, the ingredients tell the story.
  {
    "id"              : "bake_simple_pie",
    "station"         : "oven",
    "inputs"          : {"flour": 1},
    "outputs"         : {"simple_pie": 1},
    "workAmount"      : 14,
    "toolTierRequired": 0,
    "dynamicRecipe"   : {
      "filling1": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1,
        "default"          : {"name": "Simple Pie", "description": "A single filling baked into a pastry crust."}
      }
    }
  },
  {
    "id"              : "bake_pie",
    "station"         : "oven",
    "inputs"          : {"flour": 1},
    "outputs"         : {"meat_pie": 1},
    "workAmount"      : 16,
    "toolTierRequired": 0,
    "dynamicRecipe"   : {
      "filling1": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1,
        "default"          : {"name": "Pie", "description": "Two fillings baked into a pastry crust — a hot meal in the hand."}
      },
      "filling2": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1
      }
    }
  },
  {
    "id"              : "bake_hearty_pie",
    "station"         : "oven",
    "inputs"          : {"flour": 2},
    "outputs"         : {"hearty_pie": 1},
    "workAmount"      : 20,
    "toolTierRequired": 0,
    "dynamicRecipe"   : {
      "filling1": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1,
        "default"          : {"name": "Hearty Pie", "description": "A deep, three-filling pie under a thick crust. A feast in itself."}
      },
      "filling2": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1
      },
      "filling3": {
        "acceptsCategories": ["meat", "fish", "vegetable", "fruit"],
        "quantity"         : 1
      }
    }
  },
  // TODO(honey): a sweetened pie / honey-glazed pie variant (flour + fruit + honey → a `refreshed`/treat
  // pie) once beekeeping (ENTITIES D) makes honey obtainable. Skipped now — honey has no source yet.
  // BREW (fermenter, passive timers): any grain → malt → ale; grapes/apples/berries → wine; honey → mead.
  {
    "id"              : "malt_grain",
    "station"         : "fermenter",
    "passive"         : true,
    "inputs"          : {"category:grain": 2},
    "outputs"         : {"malt": 2},
