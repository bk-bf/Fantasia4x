    "station"         : "campfire",
    "inputs"          : {"branch": 2},
    "outputs"         : {"spit_meat": 1},
    "workAmount"      : 2,
    "toolTierRequired": 0,
    "dynamicRecipe"   : {
      "meat": {
        "acceptsCategory": "meat",
        "quantity"       : 1,
        "variants"       : {
          "rabbit_meat" : {"name": "Rabbit on a Spit", "description": "Lean rabbit skewered over open flame."},
          "venison"     : {
            "name"          : "Venison on a Spit",
            "description"   : "Rich deer meat, charred and fragrant.",
            "nutritionBonus": 0.3
          },
          "wolf_meat"   : {
            "name"          : "Wolf Meat on a Spit",
            "description"   : "Gamey and tough, but hot food is hot food.",
            "nutritionBonus": -0.3
          },
          "bear_meat"   : {
            "name"          : "Bear Steak",
            "description"   : "Dense, fatty bear meat over open coals.",
            "nutritionBonus": 0.8
          },
          "boar_meat"   : {
            "name"          : "Boar on a Spit",
            "description"   : "Wild pork crackling over the fire.",
            "nutritionBonus": 0.2
          },
          "elk_meat"    : {
            "name"          : "Elk Roast",
            "description"   : "Prime elk, slow-cooked over embers.",
            "nutritionBonus": 0.8
          },
          "goat_meat"   : {"name": "Goat on a Spit", "description": "Mountain goat with a smoky char."},
          "chicken_meat": {
            "name"          : "Roasted Chicken",
            "description"   : "Crispy wild chicken on a branch skewer.",
            "nutritionBonus": -0.4
          },
          "rat_meat"    : {
            "name"          : "Roasted Rat",
            "description"   : "Scrappy and unpleasant. But cooked.",
            "nutritionBonus": -0.8
          }
        },
        "default"        : {
          "name"       : "Spit-Roasted Meat",
          "description": "Meat skewered on a branch and cooked over fire."
        }
      }
    }
  },
  // STEW (campfire): a pot of mixed ingredients — meat, fish, garden veg, legumes, a pinch of herbs.
  // Each slot takes ONE ingredient from the stew pool and the cook picks them, so the dish names itself
  // from what went in ("Venison & Cabbage Stew"). Tiers add slots (2 → 3 → 4 distinct ingredients), more
  // nutrition, and a longer `hearty_meal` buff. Output items carry `dynamicName: true` (see items.jsonc).
  {
    "id"              : "make_small_stew",
    "station"         : "campfire",
    "inputs"          : {},
    "outputs"         : {"small_stew": 1},
    "workAmount"      : 3,
    "toolTierRequired": 0,
    "toolRequirement" : {"workType": "cooking", "minTier": 0},
    "dynamicRecipe"   : {
      "ingredient1": {
        "acceptsCategories": ["meat", "fish", "vegetable", "legume", "herb"],
        "quantity"         : 1,
        "default"          : {"name": "Stew", "description": "A simple two-ingredient stew. Plain but filling."}
      },
      "ingredient2": {
        "acceptsCategories": ["meat", "fish", "vegetable", "legume", "herb"],
        "quantity"         : 1
      }
    }
  },
  {
    "id"              : "make_fine_stew",
