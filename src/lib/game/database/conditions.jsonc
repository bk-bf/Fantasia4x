    // ── Transient conditions ("transient": true) ─────────────────────────────
    // No severity/stages: re-derived fresh each tick from the pawn's state (see
    // PawnStateMachine.syncTransientConditions) and stored as plain ids in `pawn.transientConditions`;
    // they appear/clear on their own when their cause does. `transient: true` is the bool discriminant
    // vs the persistent conditions above (which omit it). modifiers are multipliers.
    {
        "id": "knockdown",
        "name": "Knocked Down",
        "transient": true,
        "description": "Prone from a heavy blunt blow — sprawled and helpless. Loses the next attack and is wide open to anyone standing over it; recovers after a couple of turns.",
        "color": "#ff5722",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.2, "strength": 0.5, "moveSpeed": 0.0, "workEfficiency": 0.0}
    },
    {
        "id": "collapse",
        "name": "Collapsed",
        "transient": true,
        "description": "Overwhelmed by pain — incapacitated and out of the fight, a body on the ground. Recovers only as the pain subsides.",
        "color": "#b71c1c",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        "modifiers": {"dexterity": 0.1, "strength": 0.3, "moveSpeed": 0.0, "workEfficiency": 0.0}
    },
    {
        "id"         : "eating",
        "name"       : "Eating",
        "transient"  : true,
        "description": "Mid-meal. Hunger is not accumulating.",
        "color"      : "#ef5350",
        "hidden"     : true,
        "modifiers"  : {"hungerRate": 0.0}
    },
    {
        "id"         : "sleeping",
        "name"       : "Sleeping",
        "transient"  : true,
        "description": "Resting. Metabolism slows; hunger accrues at one-third the normal rate.",
        "color"      : "#ffb300",
        "hidden"     : true,
        "modifiers"  : {"hungerRate": 0.33, "fatigueRate": 0.0}
    },
    {
        "id": "tired",
        "name": "Exhausted",
        "transient": true,
        "description": "Severe fatigue — heavy-limbed and slow-witted. Strength, dexterity and perception sag along with work and movement.",
        "color": "#ff7043",
        "floater": true,
        "charSpans": [ {"sheet": "items", "id": 25} ],
        "modifiers": {"strength": 0.7, "dexterity": 0.7, "perception": 0.8, "workEfficiency": 0.5, "moveSpeed": 0.5}
    },
    {
        "id": "winded",
        "name": "Winded",
        "transient": true,
        "description": "Out of breath — stamina spent. Strength and dexterity crater, so it can barely swing, barely dodge and barely move until stamina recovers to full.",
        "color": "#9575cd",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 126} ],
        "modifiers": {"strength": 0.5, "dexterity": 0.4, "moveSpeed": 0.3}
    },
    {
        "id": "wet",
        "name": "Wet",
        "transient": true,
        "description": "Soaked through from rain or wet ground. Chilled and sluggish — cold bites far harder (and heat far less). Dries off in the warmth or under a roof.",
        "color": "#4FA3D1",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "modifiers": {"dexterity": 0.95, "moveSpeed": 0.9, "workEfficiency": 0.95}
    },
    {
        "id": "sheltered",
        "name": "Sheltered",
        "transient": true,
        "description": "Under a roof, out of the weather. Recovers from cold and heat far faster, and a storm's gloom is held at bay.",
        "color": "#7E9FBF",
        "charSpans": [ {"sheet": "font", "id": 127} ],
        "modifiers": {"fatigueRate": 0.9}
    },
    {
        "id"         : "filthy",
        "name"       : "Filthy",
        "transient"  : true,
        "description": "Caked in grime. Demoralising and unhealthy — slows work and sours mood (disease risk later).",
        "color"      : "#8d6e63",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 177} ],
        "modifiers"  : {"workEfficiency": 0.85}
    },
    {
        "id": "intoxicated",
        "name": "Intoxicated",
        "description": "Warm and merry from drink (§F8). Drink lifts the mood and dulls pain, but the more that goes down the unsteadier the hands, eyes and feet — until it wears off. Severity rises with each cup and decays over time.",
        "color": "#D8A52A",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "stages": [
            {
                "label"      : "tipsy",
                "minSeverity": 0.0,
                "color"      : "#E8C35A",
                "modifiers"  : {"dexterity": 0.95, "perception": 0.95, "pain": 0.85}
            },
            {
                "label"      : "merry",
                "minSeverity": 0.3,
                "color"      : "#D8A52A",
                "modifiers"  : {"dexterity": 0.88, "perception": 0.9, "workEfficiency": 0.92, "pain": 0.7}
            },
            {
                "label"      : "drunk",
                "minSeverity": 0.6,
                "color"      : "#C2871A",
                "modifiers"  : {
                    "strength"      : 0.9 ,
                    "dexterity"     : 0.7 ,
                    "perception"    : 0.7 ,
