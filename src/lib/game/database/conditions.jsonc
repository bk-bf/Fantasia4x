        "charSpans"  : [ {"sheet": "font", "id": 247} ],
        "modifiers"  : {}
    },
    {
        "id"         : "photosynthesis",
        "name"       : "Photosynthetic",
        "transient"  : true,
        "description": "Sunlit skin drinks the daylight, under a bright open sky, hunger quietly fades.",
        "color"      : "#7CBF4F",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 15} ],
        "flags"      : ["racial", "environmental"],
        // TRAIT-SYSTEM-V2 §5: environment-gated — active (and draining hunger) only under an open sky
        // in bright daylight. Read by syncTransientConditions via conditionGraph.evaluatePredicate.
        "activateWhen": {"unsheltered": true, "meter": "ambientLight", "atOrAbove": 0.95},
        "modifiers"  : {}
    },
    {
        "id"         : "light_sensitive",
        "name"       : "Light-Sensitive",
        "transient"  : true,
        "description": "Daylight sears, weak, clumsy and reeling whenever caught unsheltered under an open sky.",
        "color"      : "#E8E4D8",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 15} ],
        "flags"      : ["racial", "environmental"],
        // TRAIT-SYSTEM-V2 §5: environment-gated — active only while unsheltered in daylight.
        "activateWhen": {"unsheltered": true, "meter": "ambientLight", "atOrAbove": 0.7},
        "modifiers"  : {"strength": 0.85, "dexterity": 0.85, "perception": 0.85}
    },
    {
        "id"         : "burning",
        "name"       : "Burning",
        "flags": ["combat", "fire", "dot"],
        "transient"  : true,
        "description": "Wreathed in flame, the fire eats at flesh until it is smothered or burns out. Onset chance and the burn's bite are reduced by fire resistance.",
        "color"      : "#FF5722",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 15} ],
        "modifiers"  : {"dexterity": 0.9, "moveSpeed": 0.9, "workEfficiency": 0.85}
    },
    // ── TRAIT-LIBRARY-EXPANSION §4.0: the shared blood-feast buff ─────────────
    // Stamped on ANY feeder (pawn or mob) whose blood-draining bite lands its drain (Combat
    // applyOneOnHitEffect). Strong but short (~30 in-game min) and NON-REFRESHING while active —
    // it must lapse before another feed rearms it (the anti-perma-keep cooldown).
    {
        "id": "feasted",
        "name": "Feasted",
        "flags": ["racial", "buff"],
        "transient": true,
        "description": "Gorged on fresh blood, a hot, swollen vigor floods the body for a time. Stronger, quicker, tireless while it lasts.",
        "color": "#C62828",
        "floater": true,
        "charSpans": [ {"sheet": "items", "id": 84} ],
        "modifiers": {"strength": 1.2, "dexterity": 1.15, "constitution": 1.15, "moveSpeed": 1.1, "workEfficiency": 1.1}
    },
    // ── TRAIT-LIBRARY-EXPANSION §3b/§3c: staged natural-gear conditions ──────
    // One pill per stage of each weapon/armor line (the trait's selfCondition). Armor carries
    // grantsNaturalArmor + carryPenalty + mode; weapons carry grantsNaturalWeapon + hostParts.
