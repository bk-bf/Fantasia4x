// Conditions — every transient or lasting state a pawn/mob can be in. One list, two shapes
// keyed by the "duration" discriminant:
//   "persistent" → tracked `severity` (0–1) in `pawn.conditions` that worsens/recovers through
//                  `stages` and can be lethal (malnutrition, blood_loss, hypothermia, …).
//   "transient"  → re-derived each tick into `pawn.transientConditions` (ids); a flat `modifiers`
//                  block, no severity/stages; clears itself when its cause goes away (hungry,
//                  tired, knockdown, mood_*, …). See the "Transient conditions" section below.
[
    {
        "duration": "persistent",
        "id": "encumbered",
        "name": "Encumbered",
        "description": "Carrying more than the body comfortably bears — worn armour plus pack weight against a strength-scaled limit. Slows movement, spoils evasion and aim, and tires the body faster. Overload is allowed, at a price: strength and bags (belt/back) raise the limit, armour eats most of it. Severity = load ÷ capacity (driven directly, not over time).",
        "lethalSeverity": 99,
        "stages": [
            { "label": "burdened",   "minSeverity": 0.0,  "color": "#C8A064", "modifiers": {"moveSpeed": 0.95, "dodge": 0.9, "fatigueRate": 1.1} },
            { "label": "encumbered", "minSeverity": 0.33, "color": "#D08040", "modifiers": {"moveSpeed": 0.85, "dodge": 0.75, "hitChance": 0.9, "workEfficiency": 0.9, "fatigueRate": 1.25} },
            { "label": "overloaded", "minSeverity": 0.83, "color": "#C04030", "modifiers": {"moveSpeed": 0.7, "dodge": 0.5, "hitChance": 0.8, "workEfficiency": 0.75, "fatigueRate": 1.5} }
        ]
    },
    {
        "duration": "persistent",
        "id": "dehydration",
        "name": "Dehydration",
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "description": "Lack of water — progressive and fast. Saps strength and work capacity; lethal within days if no water is drunk.",
        "lethalSeverity": 1.0,
        "driver": {
            "need"        : "thirst",
            "onset"       : 70,
            "safe"        : 40,
            "rateCritical": 0.0006,
            "rateMax"     : 0.0015,
            "recovery"    : 0.0008
        },
        "stages": [
            { "label": "thirsty", "minSeverity": 0.0, "color": "#4FC3F7", "modifiers": {"workEfficiency": 0.8, "moveSpeed": 0.9} },
            {
                "label"      : "parched",
                "minSeverity": 0.25,
                "color"      : "#29B6F6",
                "modifiers"  : {"workEfficiency": 0.7, "fatigueRate": 1.2}
            },
            {
                "label"          : "failing",
                "minSeverity"    : 0.5,
                "color"          : "#0288D1",
                "lifeThreatening": true,
                "modifiers"      : {"workEfficiency": 0.45, "fatigueRate": 1.4}
            },
            {
                "label"          : "collapsing",
                "minSeverity"    : 0.8,
                "color"          : "#01579B",
                "lifeThreatening": true,
                "modifiers"      : {"workEfficiency": 0.15, "fatigueRate": 1.6}
            }
        ]
    },
    {
        "duration": "persistent",
        "id": "malnutrition",
        "name": "Malnutrition",
        "charSpans": [ {"sheet": "font", "id": 31} ],
        "description": "A diet deficiency causing progressive physical deterioration. Reduces work capacity and ultimately leads to death if unchecked.",
        "lethalSeverity": 1.0,
        "driver": {
            "need"        : "hunger",
            "onset"       : 70,
            "safe"        : 40,
            "rateCritical": 0.0002,
            "rateMax"     : 0.0005,
            "recovery"    : 0.0003
        },
        "stages": [
            { "label": "hungry", "minSeverity": 0.0, "color": "#f57c00", "modifiers": {"workEfficiency": 0.75, "moveSpeed": 0.75} },
            {
                "label"      : "minor",
                "minSeverity": 0.2,
                "color"      : "#ef6c00",
                "modifiers"  : {"workEfficiency": 0.7, "moveSpeed": 0.7, "hungerRate": 1.1}
            },
            {
                "label"      : "moderate",
                "minSeverity": 0.35,
                "color"      : "#e65100",
                "modifiers"  : {"workEfficiency": 0.6, "hungerRate": 1.2}
            },
            {
                "label"      : "serious",
                "minSeverity": 0.5,
                "color"      : "#bf360c",
                "modifiers"  : {"workEfficiency": 0.5, "hungerRate": 1.3}
            },
            {
                "label"          : "severe",
                "minSeverity"    : 0.65,
                "color"          : "#b71c1c",
                "lifeThreatening": true,
                "modifiers"      : {"workEfficiency": 0.4, "hungerRate": 1.4}
            },
            {
                "label"          : "extreme",
                "minSeverity"    : 0.8,
