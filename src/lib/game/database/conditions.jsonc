    // ── Transient conditions ("transient": true) ─────────────────────────────
    // No severity/stages: re-derived fresh each tick from the pawn's state (see
    // PawnStateMachine.syncTransientConditions) and stored as plain ids in `pawn.transientConditions`;
    // they appear/clear on their own when their cause does. `transient: true` is the bool discriminant
    // vs the persistent conditions above (which omit it). modifiers are multipliers.
    {
        // Info-only tell (empty modifiers — never touches stats): surfaces that the body is losing blood
        // and HOW URGENT it is, staged off the blood-out ETA (severity derived in syncTransientConditions
        // as 1 − hoursToEmpty/8, so minor ≈ >4h, severe ≈ 4h, fatal ≈ 1.2h — the same ETA shown on the
        // Blood pill). Clears on its own the moment the wounds clot. The actual blood drain / death lives
        // in PawnStateMachine; this is purely the at-a-glance readout.
        "id": "bleeding",
        "name": "Bleeding",
        "flags": ["combat", "bleed", "readout"],
        "transient": true,
        "description": "Open wounds are seeping blood. On its own it does nothing to the body, it's a warning of how fast blood is being lost and how long until it runs out. Dress the wounds (or let them clot) to stop it.",
        "color": "#C62828",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 3} ],
        "stages": [
            {
                "label"      : "minor",
                "minSeverity": 0.0,
                "color"      : "#D97B5A",
                "modifiers"  : {}
            },
            {
                "label"      : "severe",
                "minSeverity": 0.5,
                "color"      : "#C62828",
                "modifiers"  : {}
            },
            {
                "label"          : "fatal",
                "minSeverity"    : 0.85,
                "color"          : "#FF1744",
                "lifeThreatening": true,
                "modifiers"      : {}
            }
        ],
        "modifiers": {}
    },
    {
        "id": "knockdown",
        "audio": "knockdown",
        "name": "Knocked Down",
        "flags": ["combat", "control"],
        "transient": true,
        "description": "Prone from a heavy blunt blow, sprawled and helpless. Loses the next attack and is wide open to anyone standing over it; the heavier the blow, the longer it stays down.",
        "color": "#ff5722",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.2, "strength": 0.5, "moveSpeed": 0.0, "workEfficiency": 0.0}
    },
    {
        "id": "collapse",
        "audio": "knockdown",
        "name": "Collapsed",
        "flags": ["combat", "incapacitated"],
        "transient": true,
        "description": "Overwhelmed by pain, incapacitated and out of the fight, a body on the ground. Recovers only as the pain subsides.",
        "color": "#b71c1c",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        // Status-animation priority — the downed ↓ glyph beats every other state tell (winded, sleeping):
        // being out of the fight is the most important thing to read at a glance.
        "priority": 100,
        // Data-driven link: while active this condition forces the pawn's FSM into COLLAPSED and gates
        // all other behaviour (PawnStateMachine reads `fsmState` instead of hardcoding the state).
        "fsmState": "Collapsed",
        // Being down is enforced by the FSM (dropped job, released draft, action gate) — so the only
        // modifier that carries weight is zeroing evasion, so a downed body is trivially hit. The old
        // dexterity/strength/moveSpeed/workEfficiency cuts were dead weight the FSM already covers.
        "modifiers": {"dodge": 0.0}
    },
    {
        "id"         : "eating",
        "name"       : "Eating",
        "flags": ["fsm"],
        "transient"  : true,
        "description": "Mid-meal. Hunger is not accumulating.",
        "color"      : "#ef5350",
        "hidden"     : true,
        "modifiers"  : {"hungerRate": 0.0}
    },
    {
        "id"         : "sleeping",
        "name"       : "Sleeping",
        "flags": ["fsm"],
        "transient"  : true,
        "description": "Resting. Metabolism slows; hunger accrues at one-third the normal rate.",
        "color"      : "#ffb300",
        "hidden"     : true,
        "priority"   : 50,
        "modifiers"  : {"hungerRate": 0.33, "fatigueRate": 0.0}
    },
    {
        "id": "tired",
        "name": "Exhausted",
        "flags": ["need", "fatigue"],
        "transient": true,
        "description": "Severe fatigue, heavy-limbed and slow-witted. Strength, dexterity and perception sag along with work and movement.",
        "color": "#ff7043",
        "floater": true,
        "charSpans": [ {"sheet": "items", "id": 25} ],
        // Onset at the exhaustion CEILING — a body normally rests (pawn seeks rest at fatigue 72, mob at
        // 60) long before this, so the debuff only bites when something keeps it awake to the cap. Pawns
        // and mobs both read this number; the "not while sleeping" suppression lives in code.
        "needOnset": {"need": "fatigue", "atOrAbove": 100},
        "modifiers": {"strength": 0.7, "dexterity": 0.7, "perception": 0.8, "workEfficiency": 0.5, "moveSpeed": 0.5}
    },
    {
        "id": "winded",
        "name": "Winded",
        "flags": ["combat", "stamina"],
        "transient": true,
        "description": "Out of breath, stamina spent. Strength and dexterity crater, so it can barely swing, barely dodge and barely move until stamina recovers to full.",
        "color": "#9575cd",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 126} ],
        "priority": 20,
        "modifiers": {"strength": 0.5, "dexterity": 0.4, "moveSpeed": 0.3}
    },
    {
        "id": "wet",
        "name": "Wet",
        "transient": true,
        "description": "Soaked through from rain or wet ground. Chilled and sluggish, cold bites far harder (and heat far less). Dries off in the warmth or under a roof.",
        "color": "#4FA3D1",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        // Onset at the FULL wetness meter (100) for EVERY entity — pawns and mobs run the same meter
        // (EnvironmentService.accrueWetness). Susceptibility differs only in FILL RATE, gated by the
        // `wetness_resistance` stat (fur/hide/fitness) — NOT a different threshold.
        "needOnset": {"need": "wetness", "atOrAbove": 100},
        // TRAIT-SYSTEM-V2 §5: soaked + a maxed cold meter → a per-second chance to catch a chill that
        // seeds/escalates hypothermia (the former inline WET_CHILL). DRIVEN by tickConditions via
        // conditionGraph.fireTriggers — behaviour-identical to the old hardcoded block.
        "flags": ["environmental", "cold-vector"],
        "triggers": [
            { "to": "hypothermia", "when": {"need": "coldExposure", "atOrAbove": 100}, "chance": 0.04, "severity": 0.04 }
        ],
        "modifiers": {"dexterity": 0.95, "moveSpeed": 0.9, "workEfficiency": 0.95}
    },
    {
        "id": "sheltered",
        "name": "Sheltered",
        "flags": ["environmental", "shelter"],
        "transient": true,
        "description": "Under a roof, out of the weather. Recovers from cold and heat far faster, dries off quickly, breaks the wind so windchill barely bites, and a storm's gloom is held at bay.",
        "color": "#7E9FBF",
        "charSpans": [ {"sheet": "font", "id": 127} ],
        "modifiers": {"fatigueRate": 0.9}
    },
    {
        "id"         : "filthy",
        "name"       : "Filthy",
        "flags": ["need", "hygiene"],
        "transient"  : true,
        "description": "Caked in grime. Demoralising and unhealthy, slows work and sours mood (disease risk later).",
        "color"      : "#8d6e63",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 177} ],
        // Onset when the `hygiene` need maxes out. PAWN-ONLY: creatures have no washing behaviour, so the
        // mob lifecycle never derives `filthy` (no hygiene need) — this threshold is read only by pawns.
        "needOnset"  : {"need": "hygiene", "atOrAbove": 100},
        "modifiers"  : {"workEfficiency": 0.85}
    },
    {
        "id": "intoxicated",
        "name": "Intoxicated",
        "flags": ["food", "drink"],
        "description": "Warm and merry from drink (§F8). Drink lifts the mood and dulls pain, but the more that goes down the unsteadier the hands, eyes and feet, until it wears off. Severity rises with each cup and decays over time.",
        "color": "#D8A52A",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "stages": [
            {
                "label"      : "tipsy",
                "minSeverity": 0.0,
                "color"      : "#E8C35A",
                "modifiers"  : {"dexterity": 0.95, "perception": 0.95, "pain": 0.85}
            },
            {
                "label"      : "merry",
                "minSeverity": 0.3,
                "color"      : "#D8A52A",
                "modifiers"  : {"dexterity": 0.88, "perception": 0.9, "workEfficiency": 0.92, "pain": 0.7}
            },
            {
                "label"      : "drunk",
                "minSeverity": 0.6,
                "color"      : "#C2871A",
                "modifiers"  : {
                    "strength"      : 0.9 ,
                    "dexterity"     : 0.7 ,
                    "perception"    : 0.7 ,
                    "workEfficiency": 0.75,
                    "moveSpeed"     : 0.85,
                    "consciousness" : 0.8 ,
                    "pain"          : 0.55
                }
            },
            {
                "label"      : "blackout drunk",
                "minSeverity": 0.85,
                "color"      : "#9C6A12",
                "modifiers"  : {
                    "strength"      : 0.7,
                    "dexterity"     : 0.4,
                    "perception"    : 0.4,
                    "workEfficiency": 0.4,
                    "moveSpeed"     : 0.5,
                    "consciousness" : 0.4,
                    "pain"          : 0.4
                }
            }
        ]
    },
    {
        "id": "nausea",
        "name": "Nausea",
        "flags": ["food", "sickness"],
        "transient": true,
        "description": "Queasy and off-colour after a bad bite. The stomach turns, clumsy, slow work and no appetite until it passes.",
        "color": "#8FAE52",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "modifiers": {"dexterity": 0.85, "workEfficiency": 0.6, "moveSpeed": 0.85, "hungerRate": 0.7}
    },
    {
        "id": "dysentery",
        "name": "Dysentery",
        "flags": ["food", "disease"],
        "transient": true,
        "description": "A gut sickness from spoiled or tainted food. Fever, cramps and fluid loss leave the body wrung out and weak, strength, dexterity and endurance all sag, the body parches faster, and it lingers for days.",
        "color": "#6E8B3D",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "modifiers": {
            "strength"      : 0.7,
            "dexterity"     : 0.7,
            "constitution"  : 0.8,
            "workEfficiency": 0.4,
            "moveSpeed"     : 0.7,
            "thirstRate"    : 1.6,
            "fatigueRate"   : 1.4
        }
    },
    // ── Food buffs ("transient": true, applied on eat) ───────────────────────
    // Stamped onto conditionTimers when a meal carrying a `mealBuff` is eaten (see
    // pawnQueries.applyMealBuff), exactly like nausea/intoxication — they decrement each tick and
    // auto-clear. The POINT is that meal classes differ in PURPOSE, not just nutrition: a stew is
    // endurance fare, a pie is fortifying, fruit lifts morale, herbs aid recovery. Kept deliberately
    // SUBTLE (≈5–10%) — a good meal is an edge, not a mandatory optimisation loop. modifiers = multipliers.
    {
        "id"         : "well_fed",
        "name"       : "Well Fed",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "A proper hot meal in the belly. Settled and ready to work.",
        "color"      : "#9CCC65",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"workEfficiency": 1.05}
    },
    {
        "id"         : "hearty_meal",
        "name"       : "Hearty Meal",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "A thick, stick-to-the-ribs stew. Stays filling for hours and keeps the body going.",
        "color"      : "#C8A064",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"hungerRate": 0.85, "fatigueRate": 0.92}
    },
    {
        "id"         : "nourished",
        "name"       : "Nourished",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "A full, balanced meal of meat and garden veg. The body works the better for it.",
        "color"      : "#8BC34A",
        "charSpans"  : [ {"sheet": "font", "id": 2} ],
        "modifiers"  : {"constitution": 1.05, "workEfficiency": 1.06}
    },
    {
        "id"         : "fortified",
        "name"       : "Fortified",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "A rich, hearty feast. The body is steeled, stronger, hardier, and slow to tire.",
        "color"      : "#D8A52A",
        "charSpans"  : [ {"sheet": "font", "id": 2} ],
        "modifiers"  : {"strength": 1.05, "constitution": 1.06, "fatigueRate": 0.88}
    },
    {
        "id"         : "refreshed",
        "name"       : "Refreshed",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "Sweet, cool fruit, a welcome lift. Senses sharpen and the step lightens.",
        "color"      : "#AED581",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"perception": 1.05, "dexterity": 1.03}
    },
    {
        "id"         : "soothed",
        "name"       : "Soothed",
        "flags": ["food", "buff"],
        "transient"  : true,
        "description": "Calming herbs settle the body, aches ease and weariness lifts. Good fare for the mending.",
        "color"      : "#80CBC4",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"fatigueRate": 0.9, "pain": 0.95}
    },
    {
        "id"         : "mood_ecstatic",
        "name"       : "Ecstatic",
        "flags": ["mood"],
        "transient"  : true,
        "description": "In high spirits. Work efficiency is greatly boosted.",
        "color"      : "#4CAF50",
