// Conditions — every transient or lasting state a pawn/mob can be in. One list, two shapes
// discriminated by a plain `transient` BOOL (no string parsing):
//   persistent (no `transient` flag) → tracked `severity` (0–1) in `pawn.conditions` that
//                  worsens/recovers through `stages` and can be lethal (malnutrition, hypothermia…).
//   "transient": true → re-derived each tick into `pawn.transientConditions` (ids); a flat `modifiers`
//                  block, no severity/stages; clears itself when its cause goes away.
//
// modifiers (all MULTIPLIERS, 1.0 = no change): the base-stat keys — strength / dexterity /
// constitution / perception / intelligence — scale the RAW attribute EVERYWHERE it's read (combat
// damage/hit/dodge/resistance, carry, every work formula), so a severe condition genuinely cripples
// the body. workEfficiency / moveSpeed / hungerRate / fatigueRate / dodge / hitChance stack ON TOP.
[
    {
        "id": "encumbered",
        "name": "Encumbered",
        "flags": ["physical", "load"],
        "description": "Carrying more than the body comfortably bears — worn armour plus pack weight against a strength-scaled limit. Slows movement, wrecks evasion and aim (DEX), and tires the body faster. Overload is allowed, at a price: strength and bags (belt/back) raise the limit, armour eats most of it. Severity = load ÷ capacity (driven directly, not over time).",
        "lethalSeverity": 99,
        "stages": [
            {
                "label"      : "burdened",
                "minSeverity": 0.0,
                "color"      : "#C8A064",
                "modifiers"  : {"dexterity": 0.9, "moveSpeed": 0.95, "fatigueRate": 1.1}
            },
            {
                "label"      : "encumbered",
                "minSeverity": 0.33,
                "color"      : "#D08040",
                "modifiers"  : {
                    "dexterity"     : 0.7 ,
                    "strength"      : 0.9 ,
                    "moveSpeed"     : 0.85,
                    "workEfficiency": 0.85,
                    "fatigueRate"   : 1.3
                }
            },
            {
                "label"      : "overloaded",
                "minSeverity": 0.83,
                "color"      : "#C04030",
                "modifiers"  : {
                    "dexterity"     : 0.45,
                    "strength"      : 0.75,
                    "moveSpeed"     : 0.6 ,
                    "workEfficiency": 0.6 ,
                    "fatigueRate"   : 1.6
                }
            }
        ]
    },
    {
        "id": "windchilled",
        "name": "Windchilled",
        "flags": ["environmental", "wind"],
        "charSpans": [ {"sheet": "font", "id": 126} ],
        "description": "Buffeted by the wind. Graded by how hard it's blowing — slightly windy barely registers, a gale claws at balance, aim and footing and tires the body out. Severity = the tile's effective wind (driven directly, not over time): a roof or the lee of a wall/mountain blocks most of it. On its own it only nags; in the cold it bites far harder, driving hypothermia faster (windchill).",
        "lethalSeverity": 99,
        "stages": [
            {
                "label"      : "slightly windy",
                "minSeverity": 0.0,
                "color"      : "#B0C4DE",
                "modifiers"  : {"dexterity": 0.98, "moveSpeed": 0.98}
            },
            {
                "label"      : "somewhat windy",
                "minSeverity": 0.2,
