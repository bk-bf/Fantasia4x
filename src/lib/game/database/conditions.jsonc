        "id": "thick_hided", "name": "Thick Hide", "flags": ["racial", "natural-gear"], "transient": true,
        "description": "A dense, calloused hide, a light natural armor under anything worn.",
        "color": "#8B6F47", "charSpans": [ {"sheet": "items", "id": 145} ],
        "grantsNaturalArmor": 6, "carryPenalty": 0.03, "mode": "stack", "modifiers": {}
