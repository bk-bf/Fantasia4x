    {
        "id": "hypothermia",
        "name": "Hypothermia",
        "charSpans": [ {"sheet": "font", "id": 42} ],
        "description": "Prolonged exposure to cold below the pawn's comfort range. Numb fingers wreck dexterity and the stiffened body loses its strength; lethal if the pawn never warms up. Cold resistance (CON) slows onset; shelter, fire, and warmer seasons drive it back.",
        "lethalSeverity": 1.0,
        "floater": true,
        "driver": {
            "source"      : "cold",
            "onset"       : 45,
            "safe"        : 25,
