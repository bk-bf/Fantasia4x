    // ── TRAIT-LIBRARY-EXPANSION §6b: trigger-conditioned trait pills ──────────
    // Each is a trait's selfCondition, ACTIVE only while its `activateWhen` predicate holds (the
    // buff/debuff form) or carrying a `triggers` edge that fires a follow-up while active (the
    // proc form: Anemic → shock is the flagship). Pure data — the condition graph already
    // evaluates every predicate/meter used here.
    {
        "id": "hydro_vigor", "name": "Hydro-Vigor", "flags": ["racial", "trigger"], "transient": true,
        "description": "Water is home, soaked through, they move with a slick, sudden speed.",
        "color": "#4FC3C7", "floater": true, "charSpans": [ {"sheet": "items", "id": 195} ],
        "activateWhen": {"need": "wetness", "atOrAbove": 50},
        "modifiers": {"dodge": 1.2, "moveSpeed": 1.15}
    },
    {
        "id": "waterlogged", "name": "Waterlogged", "flags": ["racial", "trigger"], "transient": true,
        "description": "Soaks like felt, heavy, cold and slow whenever truly wet.",
        "color": "#4FC3C7", "floater": true, "charSpans": [ {"sheet": "items", "id": 195} ],
        "activateWhen": {"need": "wetness", "atOrAbove": 50},
        "modifiers": {"fatigueRate": 1.3, "moveSpeed": 0.85}
    },
    {
