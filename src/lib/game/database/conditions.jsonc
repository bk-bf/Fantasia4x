                "modifiers"  : {"dexterity": 0.95, "moveSpeed": 0.95, "fatigueRate": 1.05}
            },
            {
                "label"      : "fairly windy",
                "minSeverity": 0.4,
                "color"      : "#8FB0D4",
                "modifiers"  : {"dexterity": 0.9, "moveSpeed": 0.92, "workEfficiency": 0.95, "fatigueRate": 1.1}
            },
            {
                "label"      : "very windy",
                "minSeverity": 0.6,
                "color"      : "#6FA0CC",
                "modifiers"  : {"dexterity": 0.82, "moveSpeed": 0.85, "workEfficiency": 0.88, "fatigueRate": 1.2}
            },
            {
                "label"      : "extremely windy",
                "minSeverity": 0.8,
                "color"      : "#4F8FC4",
                "modifiers"  : {"dexterity": 0.72, "moveSpeed": 0.75, "workEfficiency": 0.78, "fatigueRate": 1.3}
            }
        ]
    },
    {
        "id": "fractured",
        "audio": "fracture",
        "name": "Fractured Bone",
        "flags": ["injury", "bone"],
        "description": "A cracked or shattered bone — graded by how far the break has gone. Severity tracks the worst fracture on the body: a hairline crack nags, but a fully shattered bone (bone HP driven to 0) is agony that collapses strength and dexterity and crawls all work. The struck limb's own function — manipulation for an arm, movement for a leg — is gutted on top via the body model. The limb is NOT lost: bone mends over WEEKS of rest (dressing + a caretaker speed it).",
        "lethalSeverity": 99,
        "stages": [
