    // ── On-hit combat effects (inflicted by creature natural weapons) ─────────
    // Timed transient debuffs applied when a venom/feeding/screech/tongue natural weapon lands (see
    // the weapon's `onHitEffect` in items.jsonc). Stored via conditionTimers like knockdown, so they
    // decrement each tick and auto-clear. Trigger chance is reduced by the named resistance stat.
    {
        "id": "envenomed",
        "audio": "envenomed",
        "name": "Envenomed",
        "flags": ["combat", "poison"],
        "transient": true,
        "description": "Venom courses through the blood — nauseous, weak and shaking. Strength, dexterity and endurance all fail until it passes. Onset chance is reduced by poison resistance (CON × blood filtration).",
        "color": "#7CB342",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 21} ],
        // TRAIT-SYSTEM-V2 §5: the venom churns the stomach — while envenomed, a small per-second chance
        // to also turn nauseous (a NEW secondary the graph enables; nausea decays on its own).
        "triggers": [
            { "to": "nausea", "chance": 0.015, "durationHours": 1.5 }
        ],
        "modifiers": {
            "strength"      : 0.6,
            "dexterity"     : 0.6,
            "constitution"  : 0.7,
            "workEfficiency": 0.7,
            "moveSpeed"     : 0.8,
            "fatigueRate"   : 1.3
        }
    },
    {
        "id": "bloodletting",
        "audio": "bloodletting",
        "name": "Bleeding Out",
        "flags": ["combat", "bleed"],
        "transient": true,
        "description": "A feeding wound that won't clot — light-headed and shaky as blood seeps away, hands and feet going slack. Onset chance is reduced by piercing resistance (CON); a successful bite also drains blood directly (→ shock).",
        "color": "#C62828",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 3} ],
        "modifiers": {"dexterity": 0.7, "strength": 0.8, "perception": 0.8, "moveSpeed": 0.8, "workEfficiency": 0.85}
    },
    {
        "id": "disoriented",
        "audio": "disoriented",
        "name": "Disoriented",
        "flags": ["combat", "mental"],
        "transient": true,
        "description": "Reeling from a piercing screech — senses scrambled, slow to act and easy to land a blow on. Perception and dexterity scatter. Onset chance is reduced by mental resistance (INT).",
        "color": "#AB47BC",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        "modifiers": {"perception": 0.4, "dexterity": 0.6, "intelligence": 0.7, "workEfficiency": 0.7, "moveSpeed": 0.9}
    },
    {
        "id": "ensnared",
        "audio": "ensnared",
        "name": "Ensnared",
        "flags": ["combat", "control"],
        "transient": true,
        "description": "Caught fast by a sticky tongue — rooted in place and wide open until torn free. Onset chance is reduced by blunt resistance (CON/STR — wrenching free).",
        "color": "#8D6E63",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.4, "moveSpeed": 0.0}
    },
    // ── Weapon-signature on-hit effects (crafted-weapon `onHitEffect`) ────────
    // Same timed-transient machinery as the creature effects above, but inflicted by HELD weapons: a
    // spear shoves (knockback → the displacement is CODE in Combat.ts; this is its recovery-of-footing
    // marker), a devastating warhammer rattles the skull, a great cleaver maims the legs. Onset chance
    // is reduced by the matching resistance stat named on the weapon's onHitEffect.
    {
        "id": "staggered",
        "audio": "knockdown",
        "name": "Staggered",
        "flags": ["combat", "control"],
        "transient": true,
        "description": "Shoved back off balance by a spear thrust — reeling for footing, slow and open for a beat before recovering.",
        "color": "#E08840",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.85, "moveSpeed": 0.9}
    },
    {
        "id": "concussed",
        "audio": "knockdown",
        "name": "Concussed",
        "flags": ["combat", "mental"],
        "transient": true,
        "description": "Skull rung by a crushing hammer blow — vision swims and the head won't clear. Perception, dexterity and wakefulness all crater; a devastating follow-up is easy to land.",
        "color": "#9C6AC0",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        "modifiers": {"perception": 0.5, "dexterity": 0.6, "consciousness": 0.7, "workEfficiency": 0.5}
    },
    {
        "id": "hamstrung",
        "audio": "bloodletting",
        "name": "Hamstrung",
        "flags": ["combat", "injury"],
        "transient": true,
        "description": "A deep cut to the leg — the tendon severed, the footing gone. Barely able to move and slow to react until it mends.",
        "color": "#B5502E",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 3} ],
        "modifiers": {"moveSpeed": 0.4, "dexterity": 0.75}
    },
    // ── Racial trait conditions (ADR-023 · ADR-028) ──────────────────────────
    // The legible pill for a rare/epic/legendary body trait — pushed by syncTransientConditions for
    // every trait carrying the id as `selfCondition`, and the HUB for its combat capability:
    // `grantsNaturalWeapon` (item ids) / `grantsNaturalArmor` (0–100 defense). Natural ARMOR is gear
    // (TRAIT-SYSTEM-V2 §3): `weightKg` loads the carry budget (→ the staged `encumbered` condition,
    // like worn plate) and `mode` decides how it meets worn armour — "stack" ADDS to the worn soak
    // (armor under the clothes), "replace" competes best-of as the blocked slot's layer.
    // `photosynthesis`/`light_sensitive` are ENVIRONMENT-GATED (pushed only while active) and
    // `burning` is a combat DoT applied via onHitEffect (conditionTimers).
    {
        "id"                : "clawed",
        "name"              : "Clawed",
        "flags": ["racial", "natural-gear"],
        "transient"         : true,
        "description"       : "Curved rending claws in place of fingers — a fearsome unarmed weapon, but far too clumsy to grip a crafted tool or weapon.",
        "color"             : "#C8A064",
        "charSpans"         : [ {"sheet": "items", "id": 223} ],
        "grantsNaturalWeapon": ["rending-claws"],
        "hostParts"         : ["leftHand", "rightHand"],
        "modifiers"         : {"dexterity": 0.95}
    },
    {
        "id"               : "furred",
        "name"             : "Thick Fur",
        "flags": ["racial", "natural-gear"],
        "transient"        : true,
        "description"      : "A dense pelt — natural armor and warmth against the cold, but stifling in the heat, and no room for a mid body layer beneath it.",
        "color"            : "#8B6F47",
        "charSpans"        : [ {"sheet": "items", "id": 145} ],
        "grantsNaturalArmor": 8,
        "weightKg"         : 5,
        "mode"             : "replace",
        "modifiers"        : {}
    },
    {
        "id"               : "scaled",
        "name"             : "Scaled Hide",
        "flags": ["racial", "natural-gear"],
        "transient"        : true,
        "description"      : "Overlapping scales sheathe the body like a coat of living mail, turning aside cutting and piercing blows.",
        "color"            : "#6B8E6B",
        "charSpans"        : [ {"sheet": "items", "id": 145} ],
        "grantsNaturalArmor": 12,
        "weightKg"         : 4,
        "mode"             : "stack",
        "modifiers"        : {}
    },
    {
        "id"               : "iron_skinned",
        "name"             : "Iron Skin",
        "flags": ["racial", "natural-gear"],
        "transient"        : true,
        "description"      : "Skin set hard as armor plate — heavy natural armor that turns aside all but the most driving blows.",
        "color"            : "#9AA3AD",
        "charSpans"        : [ {"sheet": "items", "id": 145} ],
        "grantsNaturalArmor": 18,
        "weightKg"         : 12,
        "mode"             : "stack",
        "modifiers"        : {}
    },
    {
        "id"               : "dragon_scaled",
        "name"             : "Dragon Scales",
        "flags": ["racial", "natural-gear"],
        "transient"        : true,
        "description"      : "Armored draconic scales — heavy natural armor, and flesh that flame cannot touch.",
        "color"            : "#B87333",
