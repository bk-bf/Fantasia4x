// conversations.jsonc — fragment banks for the pawn conversation system (SOCIAL-LAYER §3).
// Data only: category choice, outcome rolls, and point deltas live in services/social/conversations.ts.
// Assembly: an opener (speaker A) + a reply (speaker B) + a closer, drawn from the pools below.
// Placeholders resolved at assembly: {name} = the other speaker's first name, {subject} = a draw
// from `subjects`, {weather} / {season} = the live sky and season. All strings are PLAYER-FACING.
{
  // What pawns talk about. Kept concrete and small-world: the colony, the land, the work.
  "subjects": [
    "the last hunt",
    "the state of the stores",
    "the old country",
    "a strange dream",
    "worn boots",
    "the {season} sky",
    "the price of flint",
    "wolves in the treeline",
    "the smell of the smokehouse",
    "an old scar",
    "the best way to bank a fire",
    "somebody's snoring",
    "the water barrel",
    "a song half remembered",
    "the graves on the hill",
    "what the traders carried",
    "the far mountains",
    "whose turn it is to haul",
    "a coin from home",
    "the taste of last night's stew"
  ],
  "categories": {
    "small_talk": {
      "openers": [
        "Fine {weather} for it, no?",
        "You been thinking about {subject} too?",
        "Long day. They are all long days.",
        "Heard anything of {subject}?",
        "That {weather} is settling in, I reckon.",
        "Come, sit a moment. Tell me of {subject}."
      ],
      "replies_good": [
        "Ha, true enough.",
        "Aye, that it is.",
        "You always notice these things, {name}.",
        "Mm. Could be worse, could be raining arrows.",
        "Same as ever. But I do not mind it."
      ],
      "replies_bad": [
        "What do you want, {name}?",
        "I have work waiting.",
        "Mm.",
        "You talk a lot for someone with empty hands."
      ],
      "closers_good": [
        "Well. Back to it, then.",
        "Good talking, {name}.",
        "We will make something of this place yet."
      ],
      "closers_bad": [
        "Forget I asked.",
        "Suit yourself, then.",
        "Right. Back to work."
      ]
    },
    "banter": {
      "openers": [
        "Seen anything slower than {name} with a hauling sack? Me neither.",
        "You still owe me for that wager, {name}.",
        "Careful, {name}, you nearly did some work just now.",
        "I told the tale of {subject} again. It gets better each telling.",
        "If snoring were a craft, {name}, you would be a master."
      ],
      "replies_good": [
        "Ha! And you would know, would you?",
        "Keep talking. I can wait.",
        "One day I will tell them what really happened.",
        "You wound me. Do it again.",
        "That joke was old when the hills were young."
      ],
      "replies_bad": [
        "Funny. Very funny.",
        "Say that again when your hands are empty.",
        "I am not in the mood, {name}."
      ],
      "closers_good": [
        "Ah, you are all right, {name}.",
        "Come find me at the fire later.",
        "Next time the wager doubles."
      ],
      "closers_bad": [
        "It was only a joke, friend.",
        "Fine, fine. Peace.",
        "No humor in this one."
      ]
    },
    "deep_talk": {
      "openers": [
        "Do you ever think of before, {name}? Of home?",
        "I buried a friend once, over such a thing as {subject}. Never told anyone.",
        "Some nights I lie awake and listen to the dark.",
        "What do you want out of all this, {name}? Truly.",
        "I was not always the person you see hauling logs."
      ],
      "replies_good": [
        "I think of it every day. Every single day.",
        "You can tell me. I keep what I am given.",
        "Truth be told, the same fear sits in me.",
        "That is the most honest thing anyone has said here.",
        "We carry it together, then. Lighter that way."
      ],
      "replies_bad": [
        "Keep that to yourself, {name}.",
        "I do not dig in other people's graves. Do not dig in mine.",
        "Heavy talk. I have enough to carry."
      ],
      "closers_good": [
        "Thank you for hearing it.",
        "This stays between us.",
        "You are a better friend than I deserve, {name}."
      ],
      "closers_bad": [
        "Forget I spoke.",
        "As you like. The dark keeps its own counsel.",
        "Should not have said anything."
      ]
    },
    "flirt": {
      "openers": [
        "That is fine work, {name}. The hands that did it are finer.",
        "I saved you the good seat by the fire. Again.",
        "Strange. The {weather} looks kinder when you are in it.",
        "I carved this. It is yours, if you will have it.",
        "Walk the fence line with me, {name}. The company improves the view."
      ],
      "replies_good": [
        "Careful, {name}, someone might hear you.",
        "Took you long enough to say so.",
        "Then walk slowly. I am in no hurry.",
        "You have a honeyed tongue for someone covered in sawdust.",
        "Ask me again by the fire tonight."
      ],
      "replies_bad": [
        "You are sweet, {name}. But no.",
        "Save it for the next caravan.",
        "My heart is spoken for, or busy, or both.",
        "Not tonight. Not any night, I think."
      ],
      "closers_good": [
        "Tonight, then. By the fire.",
        "You have made the whole day worth it.",
        "I will hold you to that."
      ],
      "closers_bad": [
        "Well. Cannot fault a soul for trying.",
        "Forget it. Wind took the words.",
        "As you say. The fence line walks itself."
      ]
    },
    "comfort": {
      "openers": [
        "Sit. You do not have to speak, {name}. I will sit with you.",
        "They would not want you hollowed out like this. Eat something.",
        "I lost people too. The weight shifts, in time. It does not leave, but it shifts.",
        "Here. A warm bowl. Grief is lighter on a full stomach, a little.",
        "Cry if you need to. Nobody counts tears out here."
      ],
      "replies_good": [
        "Stay a while, then. Just a while.",
        "I keep looking for them at the fire. Every night I look.",
        "Thank you, {name}. Truly.",
        "The bowl helps. The company more.",
        "In time. You are sure it shifts in time?"
      ],
      "replies_bad": [
        "Leave me be, {name}.",
        "Words. What good are words.",
        "You cannot carry this for me. No one can."
      ],
      "closers_good": [
        "I am here. Tomorrow too.",
        "When it gets heavy, come find me.",
        "They were lucky to have you. So are we."
      ],
      "closers_bad": [
        "I will leave the bowl by the door.",
        "As you wish. My fire is lit if you change your mind.",
        "Grief keeps its own hours. I will come back."
      ]
    },
    "argue": {
      "openers": [
        "You left the stores open again. Again, {name}!",
        "Half a day's work and you call that a wall?",
        "I am sick of hearing about {subject} from you.",
        "You take the warm spot every night and think nobody sees.",
        "Say it to my face, not behind the woodpile."
      ],
      "replies_bad": [
        "And who made you master of the stores?",
        "Do it yourself then, if your hands are so golden!",
        "I will say it anywhere I please!",
        "You count other people's work and never your own.",
        "Enough! I am done listening to you."
      ],
      "closers_bad": [
        "This is not finished.",
        "Out of my sight, {name}.",
        "The whole camp will hear of this.",
        "Fine words from a fool."
      ]
    },
    "insult": {
      "openers": [
        "There walks the laziest pair of hands in the colony.",
        "They should trade you to the next caravan, {name}. For half a boot.",
        "I have seen mules with more wit.",
        "Everything you touch ends up crooked, {name}.",
        "The wolves would spit you back out."
      ],
      "replies_bad": [
        "Better crooked hands than a crooked tongue.",
        "Keep walking, before I forget my manners.",
        "One day that mouth will cost you teeth.",
        "At least the mule works."
      ],
      "closers_bad": [
        "Pah.",
        "Waste of breath, this one.",
        "Remember this, {name}. I will."
      ]
    }
  }
}
