  {
    // ── PRODUCTION-CHAIN-II §F — Compost Bin ──────────────────────────────────────────────────
    // A passive bin (like the charcoal clamp): pawns haul rotten food/meat/hide/carcass + hay to it
    // and it rots them down into `compost` over time (the make_compost recipe, recipes.jsonc). Compost
    // is the gating material for the Soil-Works builds below — rot + scraps become your best soil.
    "id": "compost_bin",
    "ageTier": "primitive:2",
    "passive": true,
    "name": "Compost Bin",
    "color": "#5A4326",
    "charSpans": [ {"sheet": "items", "id": 41} ],
    "transparentBg": true,
    "description": "A slatted timber bin where rotten scraps and hay break down into rich compost over days. The colony's waste becomes the farm's best soil. Feed it spoiled food, hides and hay.",
    "category": "production",
    "buildingCost": {"branch": 8, "cordage": 16},
    "workAmount": 14,
    "toolTierRequired": 0,
    "populationRequired": 1,
