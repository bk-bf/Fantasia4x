// Pawn ability definitions — non-work abilities only.
// Work abilities are defined in Work.ts (WORK_CATEGORIES) and computed by ModifierSystem.
// "category"  — UI grouping: "combat" | "survival" | "physical" | "mental" | "special"
// "formula"   — expression evaluated at runtime: 1.0 + (STAT − 10) × scale
[
    // ── Combat ────────────────────────────────────────────────────────────────────
    {
        "id"         : "melee_damage",
        "category"   : "combat",
        "primaryStat": "strength",
        "formula"    : "1.0 + (STR − 10) × 0.01",
        "description": "physical attack damage multiplier"
    },
    {
        "id"         : "hit_chance",
        "category"   : "combat",
        "primaryStat": "dexterity",
        "formula"    : "1.0 + (DEX − 10) × 0.03",
        "description": "attack accuracy and to-hit roll"
    },
    {
        "id"         : "dodge",
        "category"   : "combat",
        "primaryStat": "dexterity",
        "formula"    : "1.0 + (DEX − 10) × 0.02",
        "description": "evasion and avoidance chance"
    },
    {
        "id"         : "knockdown_resistance",
        "category"   : "combat",
        "primaryStat": "constitution",
        "formula"    : "1.0 + (CON − 10) × 0.025",
        "description": "resistance to stagger and knockdown"
    },
    {
        "id"         : "aggro_range",
        "category"   : "combat",
        "primaryStat": "perception",
        "formula"    : "1.0 + (PER − 10) × 0.05",
        "description": "threat detection and combat engagement range"
    },
    // ── Survival ──────────────────────────────────────────────────────────────────
    {
        "id"         : "foraging_skill",
        "category"   : "survival",
        "primaryStat": "perception",
        "formula"    : "1.0 + (PER − 10) × 0.08",
        "description": "at finding food and resources"
    },
    {
        "id"         : "navigation",
        "category"   : "survival",
        "primaryStat": "intelligence",
        "formula"    : "1.0 + (INT − 10) × 0.08",
        "description": "pathfinding and orientation"
    },
    {
        "id"         : "weather_resistance",
        "category"   : "survival",
        "primaryStat": "constitution",
        "formula"    : "1.0 + (CON − 10) × 0.10",
        "description": "resistance to harsh weather"
    },
    {
        "id"         : "disease_resistance",
        "category"   : "survival",
        "primaryStat": "constitution",
        "formula"    : "1.0 + (CON − 10) × 0.10",
        "description": "immunity to diseases"
    },
    // ── Physical ──────────────────────────────────────────────────────────────────
    {
        "id"         : "carry_capacity",
        "category"   : "physical",
        "primaryStat": "strength",
        "formula"    : "1.0 + (STR − 10) × 0.12",
        "description": "carrying capacity"
    },
    {
        "id"         : "movement_speed",
        "category"   : "physical",
        "primaryStat": "dexterity",
        "formula"    : "1.0 + (DEX − 10) × 0.05",
        "description": "movement speed"
    },
    {
        "id"         : "stamina",
        "category"   : "physical",
        "primaryStat": "constitution",
        "formula"    : "1.0 + (CON − 10) × 0.10",
        "description": "physical endurance"
    },
    {
        "id"         : "health_regeneration",
        "category"   : "physical",
        "primaryStat": "constitution",
        "formula"    : "1.0 + (CON − 10) × 0.08",
        "description": "natural healing"
    },
    // ── Mental ────────────────────────────────────────────────────────────────────
    {
        "id"         : "learning_speed",
        "category"   : "mental",
        "primaryStat": "intelligence",
        "formula"    : "1.0 + (INT − 10) × 0.05",
        "description": "learning ability"
    },
    {
