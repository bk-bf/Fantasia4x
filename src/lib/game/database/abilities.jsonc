        "description": "information retention"
    },
    {
        "id"         : "focus",
        "category"   : "mental",
        "primaryStat": "perception",
        "formula"    : "1.0 + (PER − 10) × 0.08",
        "description": "concentration ability"
    },
    {
        "id"         : "social_influence",
        "category"   : "mental",
        "primaryStat": "charisma",
        "formula"    : "1.0 + (CHA − 10) × 0.10",
        "description": "social skills"
    },
    // ── Special ───────────────────────────────────────────────────────────────────
    {
        "id"         : "leadership",
        "category"   : "special",
        "primaryStat": "charisma",
