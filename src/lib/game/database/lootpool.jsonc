        "bodyOuter": {"chance": 0.85, "pick": [{"id": "plate_cuirass", "w": 2}, {"id": "ceremonial_plate", "w": 1}]},
        "headOuter": {"chance": 0.6,  "pick": [{"id": "great_helm", "w": 1}]},
        "boots":     {"chance": 0.6,  "pick": [{"id": "iron_shod_boots", "w": 1}]}
      }
    }
  }
}
