    // ═══ §2e: a second variant for every remaining creature (2026-07-11) ══════════════════
    // Each un-laddered base got `species`/`tier:2` stamped; here is ONE sibling apiece (young T1 /
    // elder T3) so every species has >=2 members and the hover "<Species>, <Variant>" never shows
    // an empty variant slot. Fields copied from the base; charSpans reuse the base sprite (placeholder).
    {
        "id": "dire_rat",
        "audio": "rustle",
        "name": "Dire Rat",
        "flavor": "Grown to the size of a hound on rich filth, and long past bolting from a raised stick. It holds its ground behind a mouthful of teeth, and its coarse hide will at least turn a draught.",
        "threatLevel"   : 3,    // DPS 7.6 | effHP 48 | skirmisher
        "entityClass": "animal",
        "charSpans": [{"sheet": "creatures", "id": 205}],
        "fg": [0.55, 0.45, 0.4],
