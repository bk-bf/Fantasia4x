  {
    // Water subterrains are placed by WorldGenerator's decoupled water field (Terrains.getWaterLevel),
    // NOT by biome detail-noise — so they carry no "biomes" key. They previously keyed off swamp/river,
    // which confined water almost entirely to swamps. Kept in the dict so generateWorld can name them.
    "id"          : "shallow_water",
    "displayName" : "Shallow Water",
    "walkable"    : true,
    "movementCost": 2.5,
    "charSpans"   : [ {"literal": "~"} ],
