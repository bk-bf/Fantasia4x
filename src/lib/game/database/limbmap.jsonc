// limbmap.jsonc — body plans (anatomies) per creature CATEGORY, so a wolf carries paws + a tail, not a
// humanoid's fingers/toes. Structure:
//
//   "shared.parts" — the universal catalog: internal organs + the common head/torso outer parts every
//       standard-bodied creature has. Defined ONCE here so plans don't repeat them.
//
//   "plans" — one self-contained block PER body plan, co-locating its OWN parts with its limb layout:
//       "parts"  — parts unique to this plan (humanoid fingers, quadruped paws, avian wings, hooves…).
//       "limbs"  — limbId → [partId, …]: the limbs this plan has and which parts hang off each.
//     Every plan's parts (+ shared) merge into ONE global PART_DEF_MAP, so a plan's `limbs` may reuse
//     parts declared by another plan (quadruped_hooved reuses quadruped's leg segments + tail).
//
//   Part fields: size (default HP at bodyScale 1.0 — per-creature maxHp = round(size×bodyScale), set at
//   spawn; the map never stores final HP and does NOT drive the blood pool), bleedRatio, hitWeight
//   (0 = internal organ, never rolled), isVital, isPaired, containedIn, bone (can fracture), critical
//   (destroying it = instant death). The core organs (brain/heart/lungs) must exist on every plan so the
//   capacity model (consciousness/breathing/blood) resolves; the `moving` capacity reads "leg" limbs,
//   `manipulation` reads "arm" limbs.
//
// Add `limbMap: "<plan>"` to a creature in creatures.jsonc; pawns default to "humanoid".
{
  "shared": {
    "parts": {
      // ── Internal organs (hitWeight 0 — shielded, never rolled directly) ───────────────────────────
      "brain"       : {"size": 30, "bleedRatio": 0.05, "hitWeight": 0, "isVital": true, "containedIn": "skull"},
      "heart"       : {"size": 20, "bleedRatio": 0.08, "hitWeight": 0, "isVital": true, "containedIn": "chest"},
      "leftLung"    : {"size": 30, "bleedRatio": 0.06, "hitWeight": 0, "isPaired": true, "containedIn": "chest"},
      "rightLung"   : {"size": 30, "bleedRatio": 0.06, "hitWeight": 0, "isPaired": true, "containedIn": "chest"},
      "liver"       : {"size": 25, "bleedRatio": 0.05, "hitWeight": 0, "containedIn": "abdomen"},
      "stomach"     : {"size": 20, "bleedRatio": 0.03, "hitWeight": 0, "containedIn": "abdomen"},
      "leftKidney"  : {"size": 15, "bleedRatio": 0.02, "hitWeight": 0, "isPaired": true, "containedIn": "abdomen"},
      "rightKidney" : {"size": 15, "bleedRatio": 0.02, "hitWeight": 0, "isPaired": true, "containedIn": "abdomen"},
      "spine"       : {"size": 40, "bleedRatio": 0.04, "hitWeight": 0, "containedIn": "chest"},
      // ── Common head + torso outer parts ──────────────────────────────────────────────────────────
      "skull"       : {"size": 45, "bleedRatio": 0.04, "hitWeight": 13, "bone": true, "critical": true, "weapons": ["headbutt", "antler"]},
      "jaw"         : {"size": 25, "bleedRatio": 0.02, "hitWeight": 2, "bone": true, "weapons": ["bite", "tusk", "tongue", "screech"]},
      "nose"        : {"size": 15, "bleedRatio": 0.01, "hitWeight": 0.4},
      "snout"       : {"size": 20, "bleedRatio": 0.02, "hitWeight": 3, "bone": true, "weapons": ["tusk", "bite"]},
      "leftEye"     : {"size": 10, "bleedRatio": 0.01, "hitWeight": 0.2, "isPaired": true},
      "rightEye"    : {"size": 10, "bleedRatio": 0.01, "hitWeight": 0.2, "isPaired": true},
      "leftEar"     : {"size": 10, "bleedRatio": 0.005, "hitWeight": 0.2, "isPaired": true},
      "rightEar"    : {"size": 10, "bleedRatio": 0.005, "hitWeight": 0.2, "isPaired": true},
      "chest"       : {"size": 80, "bleedRatio": 0.12, "hitWeight": 32, "bone": true, "weapons": ["charge", "slam"]},
      "abdomen"     : {"size": 70, "bleedRatio": 0.1, "hitWeight": 24}
    }
  },
  "plans": {
    "humanoid": {
      "parts": {
        "leftShoulder"     : {"size": 40, "bleedRatio": 0.03, "hitWeight": 1, "isPaired": true, "bone": true},
