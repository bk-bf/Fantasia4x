        "flavorLine": "even a scratch stays angry on them for weeks",
        "effects": {"healRate": -0.3, "diseaseResistance": -0.1}
    },
    {
        "id": "night-blind", "scope": "racial", "rarity": "negative", "kind": "attribute",
        "name": "Night-Blind", "description": "Nearly helpless once the light fails.",
        "flavorLine": "dusk closes on them like a drawn hood",
        "effects": {"nightVision": -0.4}
    },
    {
        "id": "thin-blooded", "scope": "racial", "rarity": "negative", "kind": "passive",
        "name": "Wan", "description": "A pale, sluggish constitution that holds neither warmth nor vigour against sickness.",
        "flavorLine": "the first frost of the year already sinks deep into them",
        "effects": {"coldResistance": -0.25, "diseaseResistance": -0.1}
    },
    {
        "id": "pox-marked", "scope": "racial", "rarity": "negative", "kind": "passive",
        "name": "Pox-Ridden", "description": "Never quite shed the childhood plagues — quick to sicken, slow to recover.",
        "flavorLine": "old pockmarks stipple them like hail-struck clay",
        "effects": {"diseaseResistance": -0.15, "healRate": -0.1}
    },
    {
        "id": "stiff-jointed", "scope": "racial", "rarity": "negative", "kind": "attribute",
        "name": "Maladroit", "description": "Awkward and inept at fine work — slow, fumbling craftwork.",
        "flavorLine": "delicate work seems to fight them at every turn",
        "effects": {"workSpeed": {"crafting": 0.85, "construction": 0.95}}
    },

    // ══ PERSONAL — temperament / aptitude, one INDIVIDUAL pawn at a time ═══════════
    {
