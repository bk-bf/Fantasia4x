            { "id": "crushing-grip", "scope": "racial", "kind": "passive", "name": "Crushing Grip", "description": "A grip that splits hafts — stone weight behind every wielded blow.", "weaponBonus": {"damage": 0.2}, "effects": {"strengthBonus": 1} },
            { "id": "tremor-sense", "scope": "racial", "kind": "passive", "name": "Tremor Sense", "description": "Reads the ground's tremors through the soles — little moves nearby unnoticed.", "selfCondition": "tremor_sense", "effects": {"perceptionBonus": 2} },
            { "id": "aura-fortitude", "scope": "racial", "kind": "passive", "name": "Guardian's Aura", "description": "A mountain's stillness radiates from them — friends within a few strides stand firmer.", "aura": { "condition": "fortitude", "radius": 4, "affects": "allies" }, "effects": {} }
        ]
    },
