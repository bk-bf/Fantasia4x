    // ═══════════════════════════════════════════════════════════════════════════
    // §2 · Core-stat progressions — single-stat ladders (±1/±3/±5), trade-offs,
    // two-stat combined swings, and the all-stats grand pulls (+5 all = legendary).
    // Positives climb common → uncommon → rare; every pure minus is flaw-tier.
    // ═══════════════════════════════════════════════════════════════════════════
    { "id": "str-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Strapping", "description": "A solid, capable frame — real force in the arm.", "effects": {"strengthBonus": 1} },
    { "id": "str-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Powerful", "description": "Genuinely powerful — loads and blows that stagger others.", "effects": {"strengthBonus": 3} },
    { "id": "str-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Mighty", "description": "Strength spoken of in other settlements.", "flavorLine": "they lift as three and strike as five", "effects": {"strengthBonus": 5} },
    { "id": "str-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Slight", "description": "A light, unforceful frame.", "effects": {"strengthPenalty": 1} },
    { "id": "str-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Feeble", "description": "Weak in the arm and back — heavy work defeats them.", "effects": {"strengthPenalty": 3} },
    { "id": "str-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Enfeebled", "description": "Barely able to lift their own tools.", "effects": {"strengthPenalty": 5} },
    { "id": "dex-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Nimble", "description": "Quick, sure movements.", "effects": {"dexterityBonus": 1} },
    { "id": "dex-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Deft", "description": "Hands and feet that never miss their mark.", "effects": {"dexterityBonus": 3} },
    { "id": "dex-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Quicksilver", "description": "Moves like poured quicksilver — almost too fast to follow.", "flavorLine": "they are gone from where the eye puts them", "effects": {"dexterityBonus": 5} },
    { "id": "dex-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Awkward", "description": "A half-beat behind in everything.", "effects": {"dexterityPenalty": 1} },
    { "id": "dex-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Fumbling", "description": "Drops, trips and knocks things from tables.", "effects": {"dexterityPenalty": 3} },
    { "id": "dex-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Palsied", "description": "Hands that shake at any fine task.", "effects": {"dexterityPenalty": 5} },
    { "id": "con-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Robust", "description": "Healthy and hard to wear down.", "effects": {"constitutionBonus": 1} },
    { "id": "con-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Rugged", "description": "Endures what breaks others — weather, work and wounds.", "effects": {"constitutionBonus": 3} },
    { "id": "con-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Indomitable", "description": "A body that simply refuses to fail.", "flavorLine": "sickness and season pass over them like weather over stone", "effects": {"constitutionBonus": 5} },
    { "id": "con-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Soft", "description": "Tires and sickens a little easier than most.", "effects": {"constitutionPenalty": 1} },
    { "id": "con-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Infirm", "description": "Never quite well — hard seasons hit them first and worst.", "effects": {"constitutionPenalty": 3} },
    { "id": "con-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Decrepit", "description": "Worn through — every effort costs them dearly.", "effects": {"constitutionPenalty": 5} },
    { "id": "per-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Attentive", "description": "Notices what others walk past.", "effects": {"perceptionBonus": 1} },
    { "id": "per-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Perceptive", "description": "Very little happens nearby without their knowing.", "effects": {"perceptionBonus": 3} },
    { "id": "per-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Uncanny", "description": "Seems to know things before there is any way to know them.", "flavorLine": "they turn to face trouble before it has made a sound", "effects": {"perceptionBonus": 5} },
    { "id": "per-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Inattentive", "description": "Misses the small tells.", "effects": {"perceptionPenalty": 1} },
    { "id": "per-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Absent", "description": "Forever elsewhere — the world must shout to reach them.", "effects": {"perceptionPenalty": 3} },
    { "id": "per-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Heedless", "description": "Would walk past a fire in their own house.", "effects": {"perceptionPenalty": 5} },
    { "id": "int-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Clever", "description": "Quick to see how a thing works.", "effects": {"intelligenceBonus": 1} },
    { "id": "int-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Brilliant", "description": "A mind that leaps where others climb.", "effects": {"intelligenceBonus": 3} },
    { "id": "int-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Genius", "description": "A once-a-generation mind.", "flavorLine": "problems seem to solve themselves in their presence", "effects": {"intelligenceBonus": 5} },
    { "id": "int-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Simple", "description": "Takes things slowly and plainly.", "effects": {"intelligencePenalty": 1} },
    { "id": "int-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Dim", "description": "New ideas reach them slowly, as through deep water.", "effects": {"intelligencePenalty": 3} },
    { "id": "int-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Witless", "description": "Must be shown a thing many times, and then shown again.", "effects": {"intelligencePenalty": 5} },
    { "id": "cha-plus-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Affable", "description": "Easy company — folk warm to them.", "effects": {"charismaBonus": 1} },
    { "id": "cha-plus-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Charming", "description": "Wins rooms without seeming to try.", "effects": {"charismaBonus": 3} },
    { "id": "cha-plus-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Magnetic", "description": "Folk follow them through doors they'd never open alone.", "flavorLine": "a room turns toward them like grass to the sun", "effects": {"charismaBonus": 5} },
    { "id": "cha-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Aloof", "description": "Keeps folk at arm's length without meaning to.", "effects": {"charismaPenalty": 1} },
    { "id": "cha-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Off-Putting", "description": "Something in their manner sets teeth on edge.", "effects": {"charismaPenalty": 3} },
    { "id": "cha-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Repellent", "description": "Empties a bench just by sitting on it.", "effects": {"charismaPenalty": 5} },
    // ── §2b · Stat trade-offs (+N / −N: net-neutral, cheap, shaped) ─────────────
    { "id": "str-for-dex-1", "scope": "racial", "rarity": "common", "kind": "stat", "name": "Solid", "description": "Built for force over finesse, a little.", "effects": {"strengthBonus": 1, "dexterityPenalty": 1} },
    { "id": "str-for-dex-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Bruiser", "description": "Power over finesse — a wrecking swing on slow feet.", "effects": {"strengthBonus": 3, "dexterityPenalty": 3} },
    { "id": "str-for-dex-5", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Juggernaut", "description": "A dramatic, lopsided frame — irresistible force that turns like a cart.", "effects": {"strengthBonus": 5, "dexterityPenalty": 5} },
    { "id": "dex-for-str-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Willowy", "description": "Finesse over power — quick and precise, nothing behind it.", "effects": {"dexterityBonus": 3, "strengthPenalty": 3} },
    { "id": "con-for-int-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Bull-Headed", "description": "Body over mind — endures anything, understands less.", "effects": {"constitutionBonus": 3, "intelligencePenalty": 3} },
    { "id": "int-for-con-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Bookish", "description": "Mind over body — brilliant at the desk, wilting in the field.", "effects": {"intelligenceBonus": 3, "constitutionPenalty": 3} },
    { "id": "per-for-cha-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Watchful Recluse", "description": "Sees all, charms none.", "effects": {"perceptionBonus": 3, "charismaPenalty": 3} },
    { "id": "cha-for-per-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Glad-Hander", "description": "All warmth and welcome, little notice of anything else.", "effects": {"charismaBonus": 3, "perceptionPenalty": 3} },
    { "id": "str-for-int-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Brute", "description": "Muscle over sense.", "effects": {"strengthBonus": 3, "intelligencePenalty": 3} },
    { "id": "int-for-cha-3", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Cold Intellect", "description": "Brilliant, and chilly with it.", "effects": {"intelligenceBonus": 3, "charismaPenalty": 3} },
    // ── §2c · Two-stat combined swings (both up, or both down) ──────────────────
    { "id": "str-dex-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Athletic", "description": "Strong AND quick — a natural at any physical task.", "effects": {"strengthBonus": 1, "dexterityBonus": 1} },
    { "id": "str-dex-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Warrior-Built", "description": "The complete fighter's frame — power and speed together.", "effects": {"strengthBonus": 3, "dexterityBonus": 3} },
    { "id": "str-dex-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Peerless Physique", "description": "A body out of the old songs.", "flavorLine": "sculptors would weep; sparring partners already do", "effects": {"strengthBonus": 5, "dexterityBonus": 5} },
    { "id": "str-dex-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Ungainly", "description": "Neither strong nor quick.", "effects": {"strengthPenalty": 1, "dexterityPenalty": 1} },
    { "id": "str-dex-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Feeble & Fumbling", "description": "Weak and clumsy both — physical work is a trial.", "effects": {"strengthPenalty": 3, "dexterityPenalty": 3} },
    { "id": "str-dex-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Wretched Frame", "description": "A body that betrays them at every turn.", "effects": {"strengthPenalty": 5, "dexterityPenalty": 5} },
    { "id": "con-str-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Hardy Stock", "description": "Tough and strong — good working blood.", "effects": {"constitutionBonus": 1, "strengthBonus": 1} },
    { "id": "con-str-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Ox-Strong", "description": "Pulls like an ox and shrugs off the weather doing it.", "effects": {"constitutionBonus": 3, "strengthBonus": 3} },
    { "id": "con-str-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Titanic", "description": "Strength and endurance past the natural.", "flavorLine": "they were carved for burdens no one else will name", "effects": {"constitutionBonus": 5, "strengthBonus": 5} },
    { "id": "con-str-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Poor Stock", "description": "Weak working blood.", "effects": {"constitutionPenalty": 1, "strengthPenalty": 1} },
    { "id": "con-str-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Wasted Frame", "description": "Neither strength nor stamina to draw on.", "effects": {"constitutionPenalty": 3, "strengthPenalty": 3} },
    { "id": "con-str-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Ruinous Frame", "description": "A body already spent.", "effects": {"constitutionPenalty": 5, "strengthPenalty": 5} },
    { "id": "int-per-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Observant", "description": "Sharp of mind and notice both.", "effects": {"intelligenceBonus": 1, "perceptionBonus": 1} },
    { "id": "int-per-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Studious", "description": "The scholar's pairing — a keen mind fed by keen senses.", "effects": {"intelligenceBonus": 3, "perceptionBonus": 3} },
    { "id": "int-per-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "All-Seeing", "description": "Nothing escapes them, and nothing observed is wasted.", "flavorLine": "they read a room the way others read a page", "effects": {"intelligenceBonus": 5, "perceptionBonus": 5} },
    { "id": "int-per-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Distracted", "description": "Neither sharp nor watchful.", "effects": {"intelligencePenalty": 1, "perceptionPenalty": 1} },
    { "id": "int-per-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Muddled", "description": "Slow to see and slower to grasp.", "effects": {"intelligencePenalty": 3, "perceptionPenalty": 3} },
    { "id": "int-per-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Senseless", "description": "The world arrives to them late, and poorly explained.", "effects": {"intelligencePenalty": 5, "perceptionPenalty": 5} },
    { "id": "cha-int-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Personable", "description": "Bright and warm together.", "effects": {"charismaBonus": 1, "intelligenceBonus": 1} },
    { "id": "cha-int-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Silver-Tongued", "description": "The diplomat's pairing — wit that lands and words that carry.", "effects": {"charismaBonus": 3, "intelligenceBonus": 3} },
    { "id": "cha-int-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Statecraft", "description": "Born to speak for a people.", "flavorLine": "arguments end when they clear their throat", "effects": {"charismaBonus": 5, "intelligenceBonus": 5} },
    { "id": "cha-int-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Tactless", "description": "Says the wrong true thing.", "effects": {"charismaPenalty": 1, "intelligencePenalty": 1} },
    { "id": "cha-int-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Boorish", "description": "Dull company with dull opinions.", "effects": {"charismaPenalty": 3, "intelligencePenalty": 3} },
    { "id": "cha-int-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Insufferable", "description": "Wrong about everything, loudly.", "effects": {"charismaPenalty": 5, "intelligencePenalty": 5} },
    { "id": "per-dex-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Sharp", "description": "Quick eye, quick hand.", "effects": {"perceptionBonus": 1, "dexterityBonus": 1} },
    { "id": "per-dex-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Dead-Shot", "description": "The marksman's pairing — sees the mark and puts the hand to it.", "effects": {"perceptionBonus": 3, "dexterityBonus": 3} },
    { "id": "per-dex-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Peerless Shot", "description": "What they can see, they can hit.", "flavorLine": "they call the knot in the fencepost, then split it", "effects": {"perceptionBonus": 5, "dexterityBonus": 5} },
    { "id": "per-dex-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Unsteady", "description": "Poor aim, poor notice.", "effects": {"perceptionPenalty": 1, "dexterityPenalty": 1} },
    { "id": "per-dex-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Shaky", "description": "Can't see the mark and couldn't hold on it anyway.", "effects": {"perceptionPenalty": 3, "dexterityPenalty": 3} },
    { "id": "per-dex-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Hopeless Shot", "description": "A danger mostly to bystanders.", "effects": {"perceptionPenalty": 5, "dexterityPenalty": 5} },
    { "id": "con-int-plus-1", "scope": "racial", "rarity": "uncommon", "kind": "stat", "name": "Tempered", "description": "Sound of body and mind.", "effects": {"constitutionBonus": 1, "intelligenceBonus": 1} },
    { "id": "con-int-plus-3", "scope": "racial", "rarity": "rare", "kind": "stat", "name": "Sage-Wrought", "description": "The sage's pairing — a deep mind in a body that can carry it far.", "effects": {"constitutionBonus": 3, "intelligenceBonus": 3} },
    { "id": "con-int-plus-5", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Enduring Mind", "description": "Wisdom that outlasts winters, in a frame that means to see them all.", "flavorLine": "they will outthink you, and then outlive you", "effects": {"constitutionBonus": 5, "intelligenceBonus": 5} },
    { "id": "con-int-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Frayed", "description": "Neither body nor mind quite holds.", "effects": {"constitutionPenalty": 1, "intelligencePenalty": 1} },
    { "id": "con-int-minus-3", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Worn Through", "description": "Body failing, mind following.", "effects": {"constitutionPenalty": 3, "intelligencePenalty": 3} },
    { "id": "con-int-minus-5", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Broken Vessel", "description": "Little left of either strength or sense.", "effects": {"constitutionPenalty": 5, "intelligencePenalty": 5} },
    // ── §2d · All-stats grand pulls (+5 all = legendary · +3 mythic · +1 epic; the deep curses live
    //    inline under the Blighted heritage as its sub-capabilities — the dark mirror, §4) ──
    { "id": "all-plus-1", "scope": "racial", "rarity": "epic", "kind": "stat", "name": "Blessed Stock", "description": "A quietly gifted bloodline — a touch better at everything.", "flavorLine": "whatever they turn a hand to comes easier than it should", "effects": {"strengthBonus": 1, "dexterityBonus": 1, "constitutionBonus": 1, "intelligenceBonus": 1, "perceptionBonus": 1, "charismaBonus": 1} },
    { "id": "all-plus-3", "scope": "racial", "rarity": "mythic", "kind": "stat", "name": "Paragon Blood", "description": "A heroic lineage — markedly better at everything.", "flavorLine": "the old heroic blood runs true in them", "effects": {"strengthBonus": 3, "dexterityBonus": 3, "constitutionBonus": 3, "intelligenceBonus": 3, "perceptionBonus": 3, "charismaBonus": 3} },
    { "id": "all-plus-5", "scope": "racial", "rarity": "legendary", "kind": "stat", "name": "Godtouched", "description": "The once-in-a-world pawn — better at everything, by far.", "flavorLine": "whatever made them spent longer on it than on the rest of us", "effects": {"strengthBonus": 5, "dexterityBonus": 5, "constitutionBonus": 5, "intelligenceBonus": 5, "perceptionBonus": 5, "charismaBonus": 5} },
    { "id": "all-minus-1", "scope": "racial", "rarity": "negative", "kind": "stat", "name": "Ill-Made", "description": "A little worse at everything — a body and mind assembled carelessly.", "effects": {"strengthPenalty": 1, "dexterityPenalty": 1, "constitutionPenalty": 1, "intelligencePenalty": 1, "perceptionPenalty": 1, "charismaPenalty": 1} },
    // ═══════════════════════════════════════════════════════════════════════════
    // §3 · Staged natural gear — every weapon/armor line has 3 stages (S1 uncommon → S2 rare →
    // S3 epic), chained by `evolvesTo` + a `stage` flag (data only for now — a later age/ritual
    // system walks the chain). Existing traits (rending-claws, gore-horns, venomous, thick-fur,
    // scaled-hide/iron-skin, feathered) got stage flags and slot in as their line's rungs.
    // ═══════════════════════════════════════════════════════════════════════════
    {
        "id": "budding-claws", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Budding Claws", "description": "Short hardened claw-nubs — a scraping unarmed strike, the seed of a claw line.",
        "flavorLine": "their fingertips end in hard little hooks",
        "selfCondition": "blunt_clawed", "evolvesTo": "rending-claws",
        "effects": {}
    },
    {
        "id": "ripping-talons", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Ripping Talons", "description": "Great hooked talons in place of hands — devastating unarmed, hopeless at a bench, and the wounds they leave will not close unaided.",
        "flavorLine": "their hands are a raptor's killing tools",
        "selfCondition": "taloned",
        "blocksSlots": ["mainHand", "gloves"],
        "effects": {"workSpeed": {"crafting": 0.7, "leatherworking": 0.75, "construction": 0.8}}
    },
    {
        "id": "jagged-teeth", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Jagged Teeth", "description": "A mouth of jagged, uneven teeth — a real bite in a fight.",
        "flavorLine": "their smile is a fence of broken points",
        "selfCondition": "jag_toothed", "evolvesTo": "goring-fangs",
        "effects": {}
    },
    {
        "id": "goring-fangs", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Goring Fangs", "description": "Long driving fangs — a deep, punching bite.",
        "flavorLine": "long fangs show when they speak in anger",
        "selfCondition": "fanged_goring", "evolvesTo": "sabre-fangs",
        "effects": {}
    },
    {
        "id": "sabre-fangs", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Sabre Fangs", "description": "Immense sabre teeth — a bite that opens wounds no clot will close.",
        "flavorLine": "twin sabre teeth reach past their chin",
        "selfCondition": "sabre_fanged",
        "effects": {}
    },
    {
        "id": "nub-horns", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Nub Horns", "description": "Short bony horn-nubs at the brow — a driving headbutt.",
        "flavorLine": "hard nubs of horn sit above their brow",
        "selfCondition": "nub_horned", "evolvesTo": "gore-horns",
        "effects": {}
    },
    {
        "id": "great-horns", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Great Horns", "description": "A massive sweeping crown of horn — a goring charge that hurls foes flat. Nothing fits over it.",
        "flavorLine": "a crown of horn sweeps back the length of their skull",
        "selfCondition": "great_horned",
        "blocksSlots": ["headOuter", "headBase"],
        "effects": {}
    },
    {
        "id": "small-tusks", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Small Tusks", "description": "A pair of short tusks jutting from the jaw — a boar's worry-and-gore.",
        "flavorLine": "small tusks lift their lip at the corners",
        "selfCondition": "small_tusked", "evolvesTo": "tusks",
        "effects": {}
    },
    {
        "id": "tusks", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Tusks", "description": "Heavy curved tusks — a deep goring strike.",
        "flavorLine": "heavy tusks curve up past their nose",
        "selfCondition": "tusked", "evolvesTo": "great-tusks",
        "effects": {}
    },
    {
        "id": "great-tusks", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Great Tusks", "description": "Immense curved tusks that punch deep and toss the struck aside.",
        "flavorLine": "tusks like a mammoth's calves frame their face",
        "selfCondition": "great_tusked",
        "effects": {}
    },
    {
        "id": "mild-venom", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Weak Venom", "description": "Small venom sacs behind the teeth — a bite that sometimes sickens.",
        "flavorLine": "their bite leaves a numb, spreading ache",
        "selfCondition": "mild_venomous", "evolvesTo": "venomous",
        "onHitEffect": {"condition": "envenomed", "chance": 0.2, "durationHours": 1.5, "resist": "poison_resistance"},
        "effects": {"poisonResistance": 0.15}
    },
    {
        "id": "deathly-venom", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Deathly Venom", "description": "Glands running with a killing venom — few shrug off the bite, and even a held blade carries it.",
        "flavorLine": "green-black stains follow the lines of their teeth",
        "selfCondition": "deathly_venomous",
        "onHitEffect": {"condition": "envenomed", "chance": 0.6, "durationHours": 3, "resist": "poison_resistance"},
        "effects": {"poisonResistance": 0.5}
    },
    {
        "id": "ember-breath", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 1,
        "name": "Ember Breath", "description": "A smouldering heat in the throat — a short spat gout of embers that sears and can catch cloth alight.",
        "flavorLine": "their breath shimmers like air over a forge",
        "selfCondition": "ember_breathing", "evolvesTo": "searing-breath",
        "effects": {"fireResistance": 0.15}
    },
    {
        "id": "searing-breath", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 2,
        "name": "Searing Breath", "description": "A true gout of flame spat a spear-length out — burns deep, knocks the target back, and sets them alight.",
        "flavorLine": "a furnace-glow rises in their throat before they strike",
        "selfCondition": "fire_breathing", "evolvesTo": "dragonfire-breath",
        "effects": {"fireResistance": 0.3}
    },
    {
        "id": "dragonfire-breath", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Dragonfire", "description": "A roaring lance of dragonfire striking three tiles out like a spear — a true burn, a hurled target, a lingering blaze. (TODO: a real AoE cone later.)",
        "flavorLine": "when they open their jaws the light of a kiln pours out",
        "selfCondition": "dragonfire_breathing",
        "effects": {"fireResistance": 0.5}
    },
    {
        "id": "raking-talons", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Raking Talons", "description": "Curved raptor talons on the feet — a raking, slashing kick.",
        "flavorLine": "their toes end in curved raptor hooks",
        "selfCondition": "raking_taloned", "evolvesTo": "hooked-talons",
        "blocksSlots": ["boots"],
        "effects": {}
    },
    {
        "id": "hooked-talons", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Hooked Talons", "description": "Long hooked talons that seize and shear — a raptor's killing stroke.",
        "flavorLine": "walking, they click like a hawk on slate",
        "selfCondition": "hook_taloned", "evolvesTo": "raptor-talons",
        "blocksSlots": ["boots"],
        "effects": {}
    },
    {
        "id": "raptor-talons", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Raptor Talons", "description": "Immense sickle talons that disembowel — the rents they leave will not close unaided.",
        "flavorLine": "each foot carries a sickle the length of a hand",
        "selfCondition": "raptor_taloned",
        "blocksSlots": ["boots"],
        "effects": {}
    },
    {
        "id": "pecking-beak", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Pecking Beak", "description": "A hard, horn-cased mouth — a jabbing peck of a bite.",
        "flavorLine": "their mouth has set into a hard, bird-like case",
        "selfCondition": "pecking_beaked", "evolvesTo": "tearing-beak",
        "effects": {}
    },
    {
        "id": "tearing-beak", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Tearing Beak", "description": "A heavy hooked beak that tears rather than pecks.",
        "flavorLine": "a raptor's hook has replaced their mouth",
        "selfCondition": "tearing_beaked", "evolvesTo": "rending-beak",
        "effects": {}
    },
    {
        "id": "rending-beak", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Rending Beak", "description": "A great shearing beak that strips flesh from bone.",
        "flavorLine": "their beak could shear a sapling",
        "selfCondition": "rending_beaked",
        "effects": {}
    },
    // ── §3c · Armor coverings (resistance rides the covering, never an abstract number) ──
    {
        "id": "thick-hide", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Thick Hide", "description": "A dense, calloused hide — a light natural armor under anything worn.",
        "flavorLine": "their hide takes a switch-stroke without a mark",
        "selfCondition": "thick_hided", "evolvesTo": "scaled-hide",
        "effects": {}
    },
    {
        "id": "downy-coat", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Downy Coat", "description": "A soft insulating under-fur — a whisper of armor and real warmth.",
        "flavorLine": "a fine pale down covers them to the wrists",
        "selfCondition": "downy_coated", "evolvesTo": "thick-fur",
        "effects": {"coldResistance": 0.15}
    },
    {
        "id": "winter-mane", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Winter Mane", "description": "A deep shaggy winter pelt — heavy natural armor and real cold immunity, stifling in any heat, no room for a mid layer.",
        "flavorLine": "they wade the deep snow bare-armed and unbothered",
        "selfCondition": "winter_maned",
        "blocksSlots": ["bodyMid"],
        "effects": {"coldResistance": 0.45, "fireResistance": -0.2}
    },
    {
        "id": "chitin-plates", "scope": "racial", "rarity": "uncommon", "kind": "naturalGear", "stage": 1,
        "name": "Chitin Plates", "description": "Hard chitin plates over the shoulders and back — a first shell.",
        "flavorLine": "plates of dark shell ridge their shoulders",
        "selfCondition": "chitin_plated", "evolvesTo": "carapace",
        "effects": {}
    },
    {
        "id": "carapace", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Carapace", "description": "A jointed carapace cases the torso — serious natural armor, worn always.",
        "flavorLine": "a jointed shell cases them from neck to hip",
        "selfCondition": "carapaced", "evolvesTo": "ironshell",
        "effects": {}
    },
    {
        "id": "ironshell", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Ironshell", "description": "A shell dense as wrought iron — armor that rivals plate, and nearly as heavy to live in.",
        "flavorLine": "blades ring off them as off a boiler",
        "selfCondition": "ironshelled",
        "effects": {}
    },
    {
        "id": "plumed-coat", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 2,
        "name": "Plumed Coat", "description": "A full coat of stiff feathers — light natural armor and fine insulation.",
        "flavorLine": "stiff banded plumage coats their arms and back",
        "selfCondition": "plumed", "evolvesTo": "storm-plumage",
        "effects": {"coldResistance": 0.3}
    },
    {
        "id": "storm-plumage", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Storm Plumage", "description": "Dense oiled storm-feathers that shed rain and cold and turn a glancing blow.",
        "flavorLine": "rain beads and rolls off them like off a gull's back",
        "selfCondition": "storm_plumed",
        "effects": {"coldResistance": 0.4, "wetnessResistance": 0.3}
    },
    // ── §3e · Utility natural gear — slot-cost apparatus, host-gated, no defense. A grafted wing
    //    is a REAL limb (§3d): hittable, losable — shear it and the benefit goes with it. ──
    {
        "id": "budding-wings", "scope": "racial", "rarity": "rare", "kind": "naturalGear", "stage": 1,
        "name": "Budding Wings", "description": "Small half-grown wings — enough for bounding, gliding strides. No pack fits over them.",
        "flavorLine": "small wings stir under their cloak when they run",
        "selfCondition": "budding_winged", "evolvesTo": "wings",
        "grafts": [ { "limb": "left_wing", "parts": ["leftWing", "leftWingHumerus", "leftWingtip", "leftCarpometacarpus"] }, { "limb": "right_wing", "parts": ["rightWing", "rightWingHumerus", "rightWingtip", "rightCarpometacarpus"] } ],
        "blocksSlots": ["back"],
        "bodyMods": [ { "target": "skeleton", "weightKg": 4 } ],
        "effects": {}
    },
    {
        "id": "wings", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 2,
        "name": "Wings", "description": "True working wings — the ground is a place they visit. Shear a wing off and the speed goes with it; nothing wears over them.",
        "flavorLine": "the ground is a place they visit, not one they belong to",
        "selfCondition": "winged", "evolvesTo": "great-wings",
        "grafts": [ { "limb": "left_wing", "parts": ["leftWing", "leftWingHumerus", "leftWingtip", "leftCarpometacarpus"] }, { "limb": "right_wing", "parts": ["rightWing", "rightWingHumerus", "rightWingtip", "rightCarpometacarpus"] } ],
        "blocksSlots": ["back"],
        "bodyMods": [ { "target": "skeleton", "weightKg": 6 } ],
        "effects": {}
    },
    {
        "id": "great-wings", "scope": "racial", "rarity": "epic", "kind": "naturalGear", "stage": 3,
        "name": "Great Wings", "description": "Vast, powerful wings — near-flight, faster than any runner, and a whole back given over to them.",
        "flavorLine": "unfolded, their wings shade three others",
        "selfCondition": "great_winged",
        "grafts": [ { "limb": "left_wing", "parts": ["leftWing", "leftWingHumerus", "leftWingtip", "leftCarpometacarpus"] }, { "limb": "right_wing", "parts": ["rightWing", "rightWingHumerus", "rightWingtip", "rightCarpometacarpus"] } ],
        "blocksSlots": ["back"],
        "bodyMods": [ { "target": "skeleton", "weightKg": 8 } ],
        "effects": {}
    },
    {
        "id": "prehensile-tail", "scope": "racial", "rarity": "rare", "kind": "naturalGear",
        "name": "Prehensile Tail", "description": "A strong grasping tail — a third point of balance that makes them hard to catch flat. Nothing hangs at the belt beside it.",
        "flavorLine": "their tail curls and grips like a fifth limb",
        "selfCondition": "prehensile_tailed",
        "grafts": [ { "limb": "tail", "parts": ["tail", "caudalVertebrae"] } ],
        "blocksSlots": ["belt"],
        "effects": {}
    },
    {
