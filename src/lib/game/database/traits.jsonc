        "effects": {"constitutionBonus": 1, "blunt_resistance": 0.15},
        "subCapabilities": [
            { "id": "pebbled-skin", "scope": "racial", "kind": "naturalGear", "stage": 1, "name": "Pebbled Skin", "description": "Skin studded with mineral nodules — the first setting of a stone hide.", "selfCondition": "pebbled_skinned", "evolvesTo": "granite-hide", "effects": {} },
            { "id": "granite-hide", "scope": "racial", "kind": "naturalGear", "stage": 2, "name": "Granite Hide", "description": "A hide set hard as quarried granite — heavy living armor.", "selfCondition": "granite_hided", "evolvesTo": "living-rock", "effects": {} },
            { "id": "living-rock", "scope": "racial", "kind": "naturalGear", "stage": 3, "name": "Living Rock", "description": "Flesh gone to living stone — armor beyond forged plate, mineral-slow.", "selfCondition": "living_rock", "effects": {} },
