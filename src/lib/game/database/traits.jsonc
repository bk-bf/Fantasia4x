        "name": "Maladroit", "description": "Awkward and inept at fine work — slow, fumbling craftwork.",
        "flavorLine": "delicate work seems to fight them at every turn",
        "effects": {"workSpeed": {"crafting": 0.85, "construction": 0.95}}
    },

