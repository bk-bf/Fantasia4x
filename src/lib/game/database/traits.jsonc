        "flavorLine": "they meet the ground flat and heavy at every step",
        "effects": {"dexterityPenalty": 1}
    },
    // — "really shitty" commons (§2): a deeper negative pull, kind-clean (two core OR two derived) —
    {
        "id": "sluggard", "scope": "racial", "rarity": "negative", "kind": "stat",
        "name": "Sluggard", "description": "Leaden and slow — weak and clumsy at everything they set to.",
        "flavorLine": "everything about them moves at the pace of cold honey",
