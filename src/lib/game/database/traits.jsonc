        "selfCondition": "iron_skinned",
        "effects": {}
    },
    {
        "id": "rending-claws", "scope": "racial", "rarity": "rare", "kind": "naturalGear",
        "name": "Rending Claws", "description": "Curved claws for hands — devastating unarmed, but useless at a workbench.",
        "flavorLine": "in place of fingers they bear long, hooked claws that open flesh like cloth",
