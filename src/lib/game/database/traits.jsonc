    // ══ RACIAL · SUPERNATURAL — RARE race powers, each worn as a permanent condition ══
    // Coverings (feathers/fur) that grant a resistance are `passive`; armour/weapons are `naturalGear`.
    {
        "id": "feathered", "scope": "racial", "rarity": "uncommon", "kind": "passive",
        "name": "Feathered", "description": "A covering of fine down — natural insulation against the cold.",
        "flavorLine": "a down of fine feathers softens their every movement",
        "selfCondition": "feathered",
        "effects": {"coldResistance": 0.2}
    },
    {
        "id": "scaled-hide", "scope": "racial", "rarity": "rare", "kind": "naturalGear",
        "name": "Scaled Hide", "description": "Overlapping scales blunt cutting and piercing blows.",
        "flavorLine": "overlapping scales sheathe them like a coat of living mail",
        "selfCondition": "scaled",
        "effects": {}
    },
    {
        "id": "iron-skin", "scope": "racial", "rarity": "epic", "kind": "naturalGear",
        "name": "Iron Skin", "description": "Metallic skin that sets hard as armor plate — a walking suit of plate, and rarer for it.",
