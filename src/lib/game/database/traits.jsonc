    },
    {
        "id": "gaunt", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Gaunt", "description": "Wasted and spare of frame — light on their feet, but weak and fragile.",
        "flavorLine": "hunger-lean and hollow-cheeked, they carry no spare flesh",
        "effects": {"strengthPenalty": 1, "constitutionPenalty": 1, "dexterityBonus": 1}
    },
    {
        "id": "nearsighted", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Nearsighted", "description": "The far field blurs — poor at spotting and picking out detail at range.",
        "flavorLine": "the far hills are only a smear of colour to them",
        "effects": {"perceptionPenalty": 2}
    },
    {
        "id": "one-eyed", "scope": "personal", "rarity": "common", "kind": "attribute",
        "name": "One-Eyed", "description": "Half the field of view and no depth to it — a real handicap at range.",
        "flavorLine": "an old ruin of a socket sits where the second eye should be",
        "effects": {"perceptionPenalty": 2, "workSpeed": {"hunting": 0.9}}
    },
    {
        "id": "hard-of-hearing", "scope": "personal", "rarity": "common", "kind": "attribute",
        "name": "Hard-of-Hearing", "description": "Dull of ear — slow to notice what they can't see.",
        "flavorLine": "a shout must be a loud one to reach them",
        "effects": {"perceptionPenalty": 1}
    },
    {
        "id": "bad-back", "scope": "personal", "rarity": "common", "kind": "attribute",
        "name": "Bad Back", "description": "A trick spine that gives out under load — weak at heavy lifting.",
        "flavorLine": "they carry themselves with the careful stiffness of an old ache",
        "effects": {"strengthPenalty": 2, "workSpeed": {"mining": 0.9}}
    },
    {
        "id": "trembling-hands", "scope": "personal", "rarity": "common", "kind": "attribute",
        "name": "Trembling Hands", "description": "A fine tremor that ruins delicate work.",
        "flavorLine": "their hands never quite come to rest",
        "effects": {"dexterityPenalty": 1, "workSpeed": {"crafting": 0.85}, "workQuality": {"crafting": 0.9}}
    },
    {
        "id": "brittle-boned", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Brittle-Boned", "description": "Bones that crack under a hard blow — fragile where it counts.",
        "flavorLine": "their bones have a chalky, snap-prone lightness",
        "effects": {"constitutionPenalty": 1, "blunt_resistance": -0.15}
    },
    {
        "id": "short-winded", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Short-Winded", "description": "Tires fast — little stamina for sustained toil or a long chase.",
        "flavorLine": "they are blowing hard before the work is half done",
        "effects": {"constitutionPenalty": 1, "workSpeed": {"all": 0.95}}
    },
    {
        "id": "weak-stomached", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Weak-Stomached", "description": "A delicate gut — sickens on foul food and turns from bloody work.",
        "flavorLine": "a whiff of rot is enough to turn them green",
        "effects": {"diseaseResistance": -0.15, "workSpeed": {"butchery": 0.8}}
    },
    {
        "id": "scarred", "scope": "personal", "rarity": "common", "kind": "attribute",
        "name": "Scarred", "description": "Old wounds have toughened the mind if not the flesh — off-putting, but inured to pain.",
        "flavorLine": "a map of old hurts is written across their skin",
