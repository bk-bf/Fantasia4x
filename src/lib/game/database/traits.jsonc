        "id": "nocturnal", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Nocturnal", "description": "A creature of the night — sees in pitch dark as by day, but drowses under the sun.",
        "flavorLine": "they come alive under the stars and drowse beneath the sun",
        "selfCondition": "night_eyed",
        "effects": {"dexterityBonus": 1, "perceptionBonus": 1, "nightVision": 1.0}
    },

    // ══ RACIAL · LEGENDARY — very rare; a bundle, each sub-capability rolled per pawn ══
    {
        "id": "dragon-heritage", "scope": "racial", "rarity": "legendary", "kind": "passive",
