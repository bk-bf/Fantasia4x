    // ═══════════════════════════════════════════════════════════════════════════
    // §6b · Trigger-conditioned traits — the trait grants a selfCondition whose `activateWhen`
    // predicate keys it to live pawn state (wet/cold/hot/dark/pain/bloodloss/…), or whose
    // `triggers` edge fires a follow-up (Anemic → shock). One positive + one negative per
    // affliction, each tied to a lineage. Pure data on the existing condition graph.
    // The trait card surfaces the condition as a "+ pill" with its tooltip (UI).
    // ═══════════════════════════════════════════════════════════════════════════
    { "id": "hydro-vigor", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Hydro-Vigor", "description": "Water is home — soaked through, they move with a slick, sudden speed.", "flavorLine": "rain seems to loosen rather than slow them", "selfCondition": "hydro_vigor", "effects": {} },
    { "id": "waterlogged", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Waterlogged", "description": "Soaks like felt — heavy, cold and slow whenever truly wet.", "selfCondition": "waterlogged", "effects": {} },
    { "id": "coldsurge", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Coldsurge", "description": "The deep cold wakes something — quicker and surer the harder it bites.", "flavorLine": "frost puts a spring in them that summer never does", "selfCondition": "coldsurge", "effects": {} },
    { "id": "frostbrittle", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Frostbrittle", "description": "The cold sinks in fast and deep — chill turns dangerous sooner than it should.", "selfCondition": "frostbrittle", "effects": {} },
    { "id": "sun-fueled", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Sun-Fueled", "description": "Heat feeds them — stronger and steadier under a punishing sun.", "flavorLine": "the noon glare only straightens their back", "selfCondition": "sun_fueled", "effects": {} },
    { "id": "heat-faint", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Heat-Faint", "description": "Wilts in real heat — the sun presses them toward collapse faster than most.", "selfCondition": "heat_faint", "effects": {} },
    { "id": "nightbloom", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Nightbloom", "description": "They come alive in the dark — quicker, surer, harder to touch.", "flavorLine": "dusk changes them the way dawn changes birds", "selfCondition": "nightbloom", "effects": {} },
    { "id": "nyctophobic", "scope": "personal", "rarity": "negative", "kind": "passive", "name": "Night-Fear", "description": "The dark unmans them — jumpy, scattered and slow once the light fails.", "selfCondition": "nyctophobic", "effects": {} },
    { "id": "storm-fed", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Storm-Fed", "description": "Thrives when the sky turns — wind and storm quicken the blood.", "flavorLine": "they walk out INTO weather other folk bar the door against", "selfCondition": "storm_fed", "effects": {} },
    { "id": "wind-cowed", "scope": "personal", "rarity": "negative", "kind": "passive", "name": "Wind-Cowed", "description": "A hard wind cows them — hunched and slow until it drops.", "selfCondition": "wind_cowed", "effects": {} },
    { "id": "filth-thriving", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Filth-Thriving", "description": "Muck agrees with them — grime seems to settle them into their work.", "flavorLine": "they are never happier than knee-deep in the midden", "selfCondition": "filth_thriving", "effects": {"diseaseResistance": 0.15} },
    { "id": "fastidious", "scope": "personal", "rarity": "negative", "kind": "passive", "name": "Fastidious", "description": "Cannot bear their own filth — gags and sickens when left unwashed.", "selfCondition": "fastidious_gag", "effects": {} },
    { "id": "pain-maddened", "scope": "racial", "rarity": "rare", "kind": "passive", "name": "Pain-Maddened", "description": "Hurt wakes the fury — the worse the wound, the harder they hit.", "flavorLine": "wounding them is widely considered a mistake", "selfCondition": "pain_maddened", "effects": {} },
    { "id": "faint-hearted", "scope": "personal", "rarity": "negative", "kind": "passive", "name": "Faint-Hearted", "description": "Pain unmakes them — the head swims at hurts other folk fight through.", "selfCondition": "faint_hearted", "effects": {} },
    { "id": "bloodfrenzy", "scope": "racial", "rarity": "rare", "kind": "passive", "name": "Bloodfrenzy", "description": "Bled near-white, they only fight harder — a terrible dying speed.", "flavorLine": "the paler they go, the faster they get", "selfCondition": "bloodfrenzy", "effects": {} },
    { "id": "anemic", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Anemic", "description": "Thin blood that handles loss badly — bleeding presses them toward shock far sooner than most.", "selfCondition": "anemic_shock", "effects": {} },
    { "id": "feverburn", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Feverburn", "description": "Their fevers burn HOT — the body cooks an infection out where others waste under it.", "flavorLine": "their sickbeds steam; their sicknesses lose", "selfCondition": "feverburn", "effects": {} },
    { "id": "septic-prone", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Septic", "description": "Wounds go bad in them — once rot sets in, it digs deep and fast.", "selfCondition": "septic_prone", "effects": {} },
    { "id": "venom-adapted", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Venom-Adapted", "description": "Old blood remembers old poisons — venom in the veins barely slows them.", "flavorLine": "snakes have given up on their line generations ago", "selfCondition": "venom_adapted", "effects": {} },
    { "id": "thin-veined", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Thin-Veined", "description": "Venom races through them — a bite that would slow another lays them low.", "selfCondition": "thin_veined", "effects": {} },
    { "id": "emberheart", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Emberheart", "description": "Fire is an old friend — flame on the skin hurts less and is shaken off sooner.", "flavorLine": "they pluck coals from the fire bare-fingered", "selfCondition": "emberheart", "effects": {} },
    { "id": "tinder-skin", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Tinder-Skin", "description": "They catch like dry grass — once alight, the fire clings and clings.", "selfCondition": "tinder_skin", "effects": {} },
    { "id": "camel-bodied", "scope": "racial", "rarity": "uncommon", "kind": "passive", "name": "Spare-Fed", "description": "Runs long on little — hunger barely slows the stride.", "flavorLine": "they eat like birds and work like oxen", "selfCondition": "camel_bodied", "effects": {} },
    { "id": "ravenous", "scope": "racial", "rarity": "negative", "kind": "passive", "name": "Ravenous", "description": "An engine that must be fed — hunger wastes them faster than most.", "selfCondition": "ravenous_hunger", "effects": {} },
    // ═══════════════════════════════════════════════════════════════════════════
    // §4 · Eleven heritage trees (TRAIT-LIBRARY-EXPANSION) — same shape as dragon-heritage /
    // vampiric: a passive BANNER (legendary/mythic) + subCapabilities rolled one-per-pawn at spawn
    // (the rest are the future age/ritual growth pool, §4.0). Sub-capability LINES are shared
