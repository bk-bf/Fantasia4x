                "id": "dragon-claws", "scope": "racial", "kind": "naturalGear", "name": "Dragon Claws", "description": "Talons that shear through armor.",
                "selfCondition": "dragon_clawed", "effects": {}
            },
            {
                "id": "dragon-eyes", "scope": "racial", "kind": "passive", "name": "Dragon Eyes", "description": "Slitted eyes that pierce the dark.",
