        "selfCondition": "horned",
        "blocksSlots": ["headOuter", "headBase"],
        "effects": {}
    },
    {
        "id": "venomous", "scope": "racial", "rarity": "rare", "kind": "naturalGear",
        "name": "Venom Glands", "description": "Toxins lace every strike — even a held blade carries the poison.",
        "flavorLine": "their touch carries a slow, patient poison",
        "selfCondition": "venomous",
        "onHitEffect": {"condition": "envenomed", "chance": 0.35, "durationHours": 2, "resist": "poison_resistance"},
        "effects": {"poisonResistance": 0.3}
    },
    {
        "id": "thick-fur", "scope": "racial", "rarity": "rare", "kind": "naturalGear",
        "name": "Thick Fur", "description": "A heavy pelt — natural armor and cold immunity, but stifling in heat, with no room for a mid layer.",
        "flavorLine": "a deep, shaggy pelt sheds the killing cold and turns a glancing blow",
        "selfCondition": "furred",
        "blocksSlots": ["bodyMid"],
        "effects": {"coldResistance": 0.3, "fireResistance": -0.15}
    },
    {
        "id": "flame-touched", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Flame Touched", "description": "Smouldering skin — blows land alight, and neither fire nor frost bites deep.",
        "flavorLine": "warmth pours off their skin even in the deepest frost",
        "selfCondition": "flame_touched",
        "onHitEffect": {"condition": "burning", "chance": 0.3, "durationHours": 1, "resist": "fire_resistance"},
        "effects": {"fireResistance": 0.3, "coldResistance": 0.15}
    },
    {
        "id": "photosynthetic", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Photosynthetic", "description": "Sunlit skin drinks daylight — under an open sky, hunger fades.",
        "flavorLine": "sunlight feeds them as surely as bread, greening their skin",
        "selfCondition": "photosynthesis",
        "effects": {}
    },
    {
        "id": "regenerative", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Regeneration", "description": "Torn flesh knits itself whole in days.",
        "flavorLine": "torn flesh knits itself whole within days",
        "selfCondition": "regenerating",
        "effects": {"healRate": 0.6, "diseaseResistance": 0.15}
    },
    {
        "id": "ever-warm", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Ever-Warm", "description": "An inner furnace — neither killing cold nor searing heat can take hold.",
        "flavorLine": "an inner fire keeps them from ever truly feeling the cold — or the heat",
        "selfCondition": "ever_warm",
        "effects": {"fireResistance": 0.5, "coldResistance": 0.5}
    },
    {
        "id": "frost-born", "scope": "racial", "rarity": "rare", "kind": "passive",
        "name": "Frost Born", "description": "Born of the deep winter — the killing cold is home, but real heat is agony.",
        "flavorLine": "the killing cold is to them no more than a brisk morning",
