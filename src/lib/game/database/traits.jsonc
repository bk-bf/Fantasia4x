// Trait Database (ADR-023 · TRAIT-SYSTEM-V2 · ADR-028). ONE list, each trait tagged with:
//   scope  : "racial" (physiology, drawn from a RACE's pool / identity) | "personal" (temperament, an
//            INDIVIDUAL pawn carries regardless of race). NOTE: a few individual afflictions (one-eyed /
//            hard-of-hearing / bad-back + the temperament ones) sit under the racial section but are
//            scope:"personal" — the flag is authoritative, not the grouping.
//   rarity : rarities.jsonc scale — negative | common | uncommon | rare | epic | legendary. A BUDGET
//            (§2): how many attribute categories it may touch + polarity. "negative" = a pure-downside
//            FLAW (frail/clumsy/one-eyed…), drawn as an individual Gaussian-COUNT layer (Race.ts —
//            most pawns get none, a rare wretch four), NEVER race identity. common/uncommon = the
//            mundane variety pool; rare/epic = a rare race-identity CAPABILITY; legendary = a bundle.
//            Drives the card accent colour (flaw = dark red); NOT shown as a naked "supernatural" label.
//   kind   : the payload shape + validator path — STRICTLY separated (ADR-028, no mixing):
//            "stat"       — ONLY core-stat *Bonus/*Penalty deltas (baked at pawn-gen).
//            "attribute"  — ONLY derived stats.jsonc mods (workSpeed/Yield/Quality, resistances,
//                           nightVision, healRate). NEVER a core-stat rider.
//            "bodyMod"    — modifies the limbmap BODY directly (bone/flesh HP + body weight), so a
//                           dense-boned pawn genuinely fractures harder — not a blunt_resistance fudge.
//            "naturalGear"— a natural weapon/armor via a selfCondition (§3). Armor = gear (weight →
//                           encumbrance); a natural WEAPON is bound to limbmap parts (hostParts) so a
//                           pawn that loses the limb loses the weapon, exactly like a creature.
//            "passive"    — a permanent full-body condition: aura / affinity / covering / proc (§3).
//            "wound"      — a real permanent injury at generation (one-eyed → a destroyed eye, §4).
//            Reserved TODO: behavioral / needs / transformation.
//   Enforced by traitRegistry.test.ts.
//
// NAMING LAW (ADR-028): a `stat`/`attribute` trait's NAME must be mundane + generic and MUST NOT evoke
//   a natural weapon/armor or a losable body part (bone/skin/hide/scale/claw/horn/fang/eye/ear/feather…)
//   — those imply a body-model mechanic the abstract trait does NOT have, misleading the player. Only
//   bodyMod/naturalGear/passive/wound traits (which DO touch the body) may carry an anatomical name.
//
// Selection (Race.ts): each RACE rolls its identity — ~85% mundane-only, ~15% a rare/epic capability,
// ~2.5% legendary — plus a small mundane pool (3–4). Each PAWN draws AT SPAWN up to 2 racial (guaranteed
// identity first, then the race pool) + up to 3 personal → ≤5 traits, so same-race pawns differ.
//
// evolvesTo : groundwork for trait evolution — a base names the higher-rarity trait it grows into
//   (frost-loving → frost-born, adrenaline → berserker-blood). No runtime mechanic yet.
//
// effects keys (consumed): stat *Bonus/*Penalty (pawn-gen, stat-kind ONLY); workSpeed/workYield/
//   workQuality; fire/cold/poison/disease/mental/lightning/shadow/wetnessResistance + healRate; the three
//   physical *_resistance keys; nightVision. "selfCondition" links a capability trait to its permanent
//   condition PILL (which carries grantsNaturalWeapon/grantsNaturalArmor/hostParts). "bodyMods" is the
//   bodyMod payload; "wounds" the wound payload; "blocksSlots"/"onHitEffect"/"weaponBonus"/"subCapabilities".
[
    // ══ RACIAL · MUNDANE — the physiology majority (small quirks, many negative) ═══
    // — small positives / trade-offs (pure core-stat → generic names) —
    {
        "id": "sturdy", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Sturdy", "description": "Simply hardy — a body that holds up to hard use.",
        "flavorLine": "hard work and hard weather leave little mark on them",
        "effects": {"constitutionBonus": 2}
    },
    {
        "id": "stocky", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Stocky", "description": "Short, broad and solidly built — powerful, but never quick.",
        "flavorLine": "they are built low and broad, planted like fence-posts",
        "effects": {"constitutionBonus": 2, "dexterityPenalty": 1}
    },
    {
        "id": "rangy", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Rangy", "description": "Lean and light — quick and far-reaching, but easily worn down.",
        "flavorLine": "all reach and easy motion, they move with a loose, rangy grace",
        "effects": {"dexterityBonus": 2, "constitutionPenalty": 1}
    },
    {
        "id": "strong-backed", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Brawny", "description": "Powerfully built — real force behind everything they lift and swing.",
        "flavorLine": "they carry loads that would fold a lesser sort",
        "effects": {"strengthBonus": 2}
    },
    {
        "id": "keen-eyed", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Watchful", "description": "Alert and attentive, missing little around them.",
        "flavorLine": "little escapes their notice across an open field",
        "effects": {"perceptionBonus": 2}
    },
    {
        "id": "bright", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Bright", "description": "Quick to grasp and reason — though never robust with it.",
        "flavorLine": "understanding comes to them quickly, almost before the asking",
        "effects": {"intelligenceBonus": 2, "constitutionPenalty": 1}
    },
    // — bodyMod: intrinsic body-structure (real limbmap changes, §1) —
    {
        "id": "thick-skinned", "scope": "racial", "rarity": "common", "kind": "bodyMod",
        "name": "Thick-Skinned", "description": "Tough, calloused hide — soaks up cuts and scrapes before they bite deep.",
        "flavorLine": "their weathered hide takes a cut without much complaint",
        "bodyMods": [{"target": "flesh", "hpMult": 1.15}],
        "effects": {},
        "evolvesTo": "scaled-hide"
    },
    {
        "id": "waterborn", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Waterborn", "description": "Raised by river and shore — a natural in and around the water.",
        "flavorLine": "water holds no fear for them; they wade and swim like otters",
        "effects": {"workSpeed": {"fishing": 1.4, "foraging": 1.1}}
    },
    {
        "id": "marsh-dweller", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Marsh Dweller", "description": "Bred in fetid swamps, inured to rot and fever.",
        "flavorLine": "fever and foul water that fell other folk barely slow them",
        "effects": {"poisonResistance": 0.2, "diseaseResistance": 0.2, "workYield": {"foraging": 1.15}}
    },
    // — evolution BASES (mundane seeds of a supernatural, ADR-023 evolvesTo) —
    {
        "id": "frost-loving", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Frost-Loving", "description": "Takes to the cold — comfortable where others shiver, but wilting in real heat.",
        "flavorLine": "a hard frost is to them no more than a crisp morning",
        "effects": {"coldResistance": 0.15, "fireResistance": -0.1},
        "evolvesTo": "frost-born"
    },
    {
        "id": "warm-blooded", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Heat-Hardy", "description": "Runs hot — untroubled by heat, but quick to feel a chill.",
        "flavorLine": "the sun's worst never seems to trouble them",
        "effects": {"fireResistance": 0.15, "coldResistance": -0.1},
        "evolvesTo": "ever-warm"
    },
    {
        "id": "adrenaline", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Adrenal", "description": "A quick fight-or-flight surge — danger sharpens them where it freezes others.",
        "flavorLine": "danger sharpens rather than freezes them",
        "effects": {"mentalResistance": 0.1},
        "evolvesTo": "berserker-blood"
    },
    {
        "id": "heavy-boned", "scope": "racial", "rarity": "uncommon", "kind": "bodyMod",
        "name": "Heavy-Boned", "description": "Dense, weighty bone — hard to break, but a real load to carry.",
        "flavorLine": "there is a solid, planted heft to their every step",
        "bodyMods": [{"target": "skeleton", "hpMult": 1.4, "weightKg": 8}],
        "effects": {},
        "evolvesTo": "stone-bones"
    },
    {
        "id": "night-owl", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Night-Owl", "description": "Sees passably by starlight; a little slow in the glare of noon.",
        "flavorLine": "the dark holds no terror for them",
        "effects": {"nightVision": 0.35},
        "evolvesTo": "nocturnal"
    },
    {
        "id": "fast-healer", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Fast-Healer", "description": "Cuts and scrapes close a touch quicker than most.",
        "flavorLine": "their small hurts are gone almost before they are noticed",
        "effects": {"healRate": 0.2},
        "evolvesTo": "regenerative"
    },
    // — mundane NEGATIVES (the contrast layer; weighted common) —
    {
        "id": "frail", "scope": "racial", "rarity": "negative", "kind": "stat",
        "name": "Frail", "description": "Delicate and easily tired — gives out early under any real strain.",
        "flavorLine": "there is a worn thinness to them, as of a people long stretched too far",
        "effects": {"constitutionPenalty": 2}
    },
    {
        "id": "dull", "scope": "racial", "rarity": "negative", "kind": "stat",
        "name": "Dull", "description": "Slow to reason and slower to learn.",
        "flavorLine": "new ideas reach them slowly, as through deep water",
        "effects": {"intelligencePenalty": 2}
    },
    {
        "id": "clumsy", "scope": "racial", "rarity": "negative", "kind": "stat",
        "name": "Clumsy", "description": "Awkward and graceless — forever fumbling fine work.",
        "flavorLine": "willing enough at a task, but forever fumbling it",
        "effects": {"dexterityPenalty": 2}
    },
    {
        "id": "sickly", "scope": "racial", "rarity": "negative", "kind": "attribute",
        "name": "Sickly", "description": "Prone to fever and rot — every passing illness lingers.",
        "flavorLine": "every passing sickness seems to find them first",
        "effects": {"diseaseResistance": -0.2}
    },
    {
        "id": "thin-skinned", "scope": "racial", "rarity": "negative", "kind": "bodyMod",
        "name": "Thin-Skinned", "description": "Soft, delicate flesh that marks and tears with little provocation.",
        "flavorLine": "the slightest blow raises a welt on their tender skin",
        "bodyMods": [{"target": "flesh", "hpMult": 0.85}],
        "effects": {}
    },
    {
        "id": "gaunt", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Gaunt", "description": "Wasted and spare — light and quick, but weak and fragile.",
        "flavorLine": "hunger-lean and hollow, they carry nothing to spare",
        "effects": {"strengthPenalty": 1, "constitutionPenalty": 1, "dexterityBonus": 1}
    },
    {
        "id": "nearsighted", "scope": "racial", "rarity": "negative", "kind": "stat",
        "name": "Oblivious", "description": "Slow to notice things at any distance — poor at spotting and picking out detail.",
        "flavorLine": "the far hills are only a smear of colour to them",
        "effects": {"perceptionPenalty": 2}
    },
    // — personal afflictions (WOUND granters, §4): the injury IS real, applied at gen (applyTraitWounds),
    //   so its handicap flows through the body model (sight/hearing capacities, part health) —
    {
        "id": "one-eyed", "scope": "personal", "rarity": "negative", "kind": "wound",
        "name": "One-Eyed", "description": "One eye is a ruined socket — half the field of view and no depth to it.",
        "flavorLine": "an old ruin of a socket sits where the second eye should be",
        "wounds": [{"part": "leftEye", "severity": "destroyed"}],
        "effects": {}
    },
    {
        "id": "hard-of-hearing", "scope": "personal", "rarity": "negative", "kind": "wound",
        "name": "Hard-of-Hearing", "description": "One ear long dead — slow to notice what they can't see.",
        "flavorLine": "a shout must be a loud one to reach them",
        "wounds": [{"part": "leftEar", "severity": "destroyed"}],
        "effects": {}
    },
    {
        "id": "bad-back", "scope": "personal", "rarity": "negative", "kind": "wound",
        "name": "Bad Back", "description": "An old spinal injury that never truly mended — a constant, wearing ache.",
        "flavorLine": "they carry themselves with the careful stiffness of an old ache",
        "wounds": [{"part": "spine", "severity": "serious", "type": "crush"}],
        "effects": {}
    },
    {
        "id": "brittle-boned", "scope": "racial", "rarity": "negative", "kind": "bodyMod",
        "name": "Brittle-Boned", "description": "Bones that crack under a hard blow — fragile where it counts.",
