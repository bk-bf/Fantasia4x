// Trait Database (ADR-023 · TRAIT-SYSTEM-V2). ONE list, each trait tagged with:
//   scope  : "racial" (physiology, drawn from a RACE's pool / identity) | "personal" (temperament, an
//            INDIVIDUAL pawn carries regardless of race). NOTE: a few individual afflictions (one-eyed /
//            scarred / trembling-hands / bad-back / hard-of-hearing) sit under the racial section but
//            are scope:"personal" — the flag is authoritative, not the grouping.
//   rarity : rarities.jsonc scale — common | uncommon | rare | epic | legendary. A BUDGET (§2): how
//            many attribute categories it may touch + polarity. common/uncommon = the mundane pool;
//            rare/epic = a rare race-identity CAPABILITY; legendary = a rolled bundle. Drives the card
//            accent colour; NOT shown as a naked "supernatural" label.
//   kind   : "stat" (core-stat deltas only) | "attribute" (derived stats.jsonc) | "naturalGear"
//            (weapon/armor via a selfCondition) | "passive" (aura/affinity/proc condition) | "wound"
//            (real injury at gen — applier is a follow-on). Reserved TODO: behavioral/needs/transformation.
//   Enforced by traitRegistry.test.ts.
//
// Selection (Race.ts): each RACE rolls its identity — ~85% mundane-only, ~15% a rare/epic capability,
// ~2.5% legendary — plus a small mundane pool (3–4). Each PAWN draws AT SPAWN up to 2 racial (guaranteed
// identity first, then the race pool) + up to 3 personal → ≤5 traits, so same-race pawns differ.
//
// evolvesTo : groundwork for trait evolution — a base names the higher-rarity trait it grows into
//   (frost-loving → frost-born, adrenaline → berserker-blood). No runtime mechanic yet.
//
// effects keys (consumed): stat *Bonus/*Penalty (pawn-gen); workSpeed/workYield/workQuality (per
//   work-category maps or {"all": x}); fire/cold/poison/disease/mental/lightning/shadow/wetness-
//   Resistance + healRate (added on top of the matching stat); the three physical *_resistance keys;
//   nightVision. "selfCondition" links a capability trait to its permanent condition PILL (which carries
//   grantsNaturalWeapon/grantsNaturalArmor). "blocksSlots"/"onHitEffect"/"weaponBonus"/"subCapabilities".
//   §6 re-tune: illogical work bonuses + redundant flat stats on rare traits removed (no gamification).
[
    // ══ RACIAL · MUNDANE — the physiology majority (small quirks, many negative) ═══
    // — small positives / trade-offs —
    {
        "id": "sturdy", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Sturdy", "description": "Simply hardy — a body that holds up to hard use.",
        "flavorLine": "hard work and hard weather leave little mark on them",
        "effects": {"constitutionBonus": 2}
    },
    {
        "id": "stocky", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Stocky", "description": "Short, broad and heavy-boned — strong in the trunk, slow in the hand.",
        "flavorLine": "they are built low and broad, planted like fence-posts",
        "effects": {"constitutionBonus": 2, "dexterityPenalty": 1}
    },
    {
        "id": "rangy", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Rangy", "description": "Long-limbed and light — quick and reaching, but easily worn down.",
        "flavorLine": "all reach and sinew, they move with a loose, long-boned ease",
        "effects": {"dexterityBonus": 2, "constitutionPenalty": 1}
    },
    {
        "id": "strong-backed", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Strong-Backed", "description": "Powerful through the shoulders and spine.",
        "flavorLine": "they shoulder loads that would fold a lesser back",
        "effects": {"strengthBonus": 2}
    },
    {
        "id": "keen-eyed", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Keen-Eyed", "description": "Sharp-sighted, missing little at a distance.",
        "flavorLine": "little escapes their eye across an open field",
        "effects": {"perceptionBonus": 2}
    },
    {
        "id": "bright", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Bright", "description": "Quick to grasp and reason — though never robust with it.",
        "flavorLine": "understanding comes to them quickly, almost before the asking",
        "effects": {"intelligenceBonus": 2, "constitutionPenalty": 1}
    },
    {
        "id": "thick-skinned", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Thick-Skinned", "description": "Tough, calloused hide that shrugs off scrapes.",
        "flavorLine": "their weathered hide takes a cut without much complaint",
        "effects": {"cutting_resistance": 0.1, "blunt_resistance": 0.1},
        "evolvesTo": "scaled-hide"
    },
    {
        "id": "feathered", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Feathered", "description": "Light down for insulation and grace.",
        "flavorLine": "a down of fine feathers softens their every movement",
        "effects": {"dexterityBonus": 2, "constitutionPenalty": 1, "coldResistance": 0.15}
    },
    {
        "id": "amphibious", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Amphibious", "description": "Equally at home on land and in water.",
        "flavorLine": "water holds no fear for them; they breathe the shallows like air",
        "effects": {"constitutionBonus": 1, "workSpeed": {"fishing": 1.4, "foraging": 1.1}}
    },
    {
        "id": "marsh-dweller", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Marsh Dweller", "description": "Bred in fetid swamps, inured to rot and fever.",
        "flavorLine": "fever and foul water that fell other folk barely slow them",
        "effects": {"constitutionBonus": 1, "poisonResistance": 0.2, "diseaseResistance": 0.2, "workYield": {"foraging": 1.15}}
    },
    // — evolution BASES (mundane seeds of a supernatural, ADR-023 evolvesTo) —
    {
        "id": "frost-loving", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Frost-Loving", "description": "Takes to the cold — comfortable where others shiver, but wilting in real heat.",
        "flavorLine": "a hard frost is to them no more than a crisp morning",
        "effects": {"coldResistance": 0.15, "fireResistance": -0.1},
        "evolvesTo": "frost-born"
    },
    {
        "id": "warm-blooded", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Warm-Blooded", "description": "Runs hot — untroubled by heat, but quick to feel a chill.",
        "flavorLine": "the sun's worst never seems to trouble them",
        "effects": {"fireResistance": 0.15, "coldResistance": -0.1},
        "evolvesTo": "ever-warm"
    },
    {
        "id": "adrenaline", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Adrenaline", "description": "A quick fight-or-flight surge — a little stronger in a scrap, a little rasher.",
        "flavorLine": "danger sharpens rather than freezes them",
        "effects": {"strengthBonus": 1, "workSpeed": {"hunting": 1.1}},
        "evolvesTo": "berserker-blood"
    },
    {
        "id": "heavy-boned", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Heavy-Boned", "description": "Dense, weighty bone — takes a knock well, but slow with it.",
        "flavorLine": "there is a solid, planted heft to their every step",
        "effects": {"constitutionBonus": 1, "blunt_resistance": 0.15, "dexterityPenalty": 1},
        "evolvesTo": "stone-bones"
    },
    {
        "id": "night-owl", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Night-Owl", "description": "Sees passably by starlight; a little slow in the glare of noon.",
        "flavorLine": "the dark holds no terror for them",
        "effects": {"nightVision": 0.35},
        "evolvesTo": "nocturnal"
    },
    {
        "id": "fast-healer", "scope": "racial", "rarity": "uncommon", "kind": "attribute",
        "name": "Fast-Healer", "description": "Cuts and scrapes close a touch quicker than most.",
        "flavorLine": "their small hurts are gone almost before they are noticed",
        "effects": {"healRate": 0.2},
        "evolvesTo": "regenerative"
    },
    // — mundane NEGATIVES (the contrast layer; weighted common) —
    {
        "id": "frail", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Frail", "description": "Thin-boned and easily tired — the body gives out early.",
        "flavorLine": "there is a brittleness to them, as of a people worn thin",
        "effects": {"constitutionPenalty": 2}
    },
    {
        "id": "dull", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Dull", "description": "Slow to reason and slower to learn.",
        "flavorLine": "new ideas reach them slowly, as through deep water",
        "effects": {"intelligencePenalty": 2}
    },
    {
        "id": "clumsy", "scope": "racial", "rarity": "common", "kind": "stat",
        "name": "Clumsy", "description": "Heavy-handed and graceless — fumbles fine work.",
        "flavorLine": "their hands are willing but forever fumbling",
        "effects": {"dexterityPenalty": 2}
    },
    {
        "id": "sickly", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Sickly", "description": "Prone to fever and rot — every passing illness lingers.",
        "flavorLine": "every passing sickness seems to find them first",
        "effects": {"constitutionPenalty": 1, "diseaseResistance": -0.2}
    },
    {
        "id": "thin-skinned", "scope": "racial", "rarity": "common", "kind": "attribute",
        "name": "Thin-Skinned", "description": "Soft, delicate skin that marks and tears easily.",
        "flavorLine": "the slightest blow raises a welt on their tender skin",
