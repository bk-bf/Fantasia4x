    },
    {
        "id": "nausea",
        "name": "Nausea",
        "flags": ["food", "sickness"],
        "transient": true,
        "description": "Queasy and off-colour after a bad bite. The stomach turns, clumsy, slow work and no appetite until it passes.",
        "color": "#8FAE52",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "modifiers": {"dexterity": 0.85, "workEfficiency": 0.6, "moveSpeed": 0.85, "hungerRate": 0.7}
    },
    {
        "id": "dysentery",
        "name": "Dysentery",
        "flags": ["food", "disease"],
        "transient": true,
        "description": "A gut sickness from spoiled or tainted food. Fever, cramps and fluid loss leave the body wrung out and weak, strength, dexterity and endurance all sag, the body parches faster, and it lingers for days.",
        "color": "#6E8B3D",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 247} ],
        "modifiers": {
            "strength"      : 0.7,
            "dexterity"     : 0.7,
            "constitution"  : 0.8,
            "workEfficiency": 0.4,
            "moveSpeed"     : 0.7,
            "thirstRate"    : 1.6,
            "fatigueRate"   : 1.4
        }
    },
    // ── Food buffs ("transient": true, applied on eat) ───────────────────────
    // Stamped onto conditionTimers when a meal carrying a `mealBuff` is eaten (see
    // pawnQueries.applyMealBuff), exactly like nausea/intoxication — they decrement each tick and
    // auto-clear. The POINT is that meal classes differ in PURPOSE, not just nutrition: a stew is
    // endurance fare, a pie is fortifying, fruit lifts morale, herbs aid recovery. Kept deliberately
    // SUBTLE (≈5–10%) — a good meal is an edge, not a mandatory optimisation loop. modifiers = multipliers.
    {
        "id"         : "well_fed",
        "name"       : "Well Fed",
        "mood"       : "cond_well_fed",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "A proper hot meal in the belly. Settled and ready to work.",
        "color"      : "#9CCC65",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"workEfficiency": 1.05}
    },
    {
        // RALLY: stamped when a comrade talks a broken pawn back to its feet (systems/pawn/rally). Its
        // `mood` gives a modest lift (cond_rallied), and while its timer holds, shouldRollBreakdown is
        // suppressed — the grace window that stops a rally→re-break yo-yo. Purely a timed buff, no stat mods.
        "id"         : "rallied",
        "name"       : "Rallied",
        "mood"       : "cond_rallied",
        "flags"      : ["buff"],
        "transient"  : true,
        "description": "Talked back from the brink by someone who got through. Shaken still, but holding.",
        "color"      : "#8BC34A",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {}
    },
    {
        "id"         : "hearty_meal",
        "name"       : "Hearty Meal",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "A thick, stick-to-the-ribs stew. Stays filling for hours and keeps the body going.",
        "color"      : "#C8A064",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"hungerRate": 0.85, "fatigueRate": 0.92}
    },
    {
        "id"         : "nourished",
        "name"       : "Nourished",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "A full, balanced meal of meat and garden veg. The body works the better for it.",
        "color"      : "#8BC34A",
        "charSpans"  : [ {"sheet": "font", "id": 2} ],
        "modifiers"  : {"constitution": 1.05, "workEfficiency": 1.06}
    },
    {
        "id"         : "fortified",
        "name"       : "Fortified",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "A rich, hearty feast. The body is steeled, stronger, hardier, and slow to tire.",
        "color"      : "#D8A52A",
        "charSpans"  : [ {"sheet": "font", "id": 2} ],
        "modifiers"  : {"strength": 1.05, "constitution": 1.06, "fatigueRate": 0.88}
    },
    {
        "id"         : "refreshed",
        "name"       : "Refreshed",
        "mood"       : "cond_refreshed",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "Sweet, cool fruit, a welcome lift. Senses sharpen and the step lightens.",
        "color"      : "#AED581",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"perception": 1.05, "dexterity": 1.03}
    },
    {
        "id"         : "soothed",
        "name"       : "Soothed",
        "flags"      : ["food", "buff"],
        "transient"  : true,
        "description": "Calming herbs settle the body, aches ease and weariness lifts. Good fare for the mending.",
        "color"      : "#80CBC4",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"fatigueRate": 0.9, "pain": 0.95}
    },
    {
        "id"         : "mood_ecstatic",
        "name"       : "Ecstatic",
        "flags"      : ["mood"],
        "transient"  : true,
        "description": "In high spirits. Work efficiency is greatly boosted.",
        "color"      : "#4CAF50",
        "charSpans"  : [ {"sheet": "font", "id": 2} ],
        "modifiers"  : {"workEfficiency": 1.2}
    },
    {
        "id"         : "mood_content",
        "name"       : "Content",
        "flags"      : ["mood"],
        "transient"  : true,
        "description": "Feeling good. Work efficiency is slightly boosted.",
        "color"      : "#8BC34A",
        "charSpans"  : [ {"sheet": "font", "id": 1} ],
        "modifiers"  : {"workEfficiency": 1.1}
    },
    {
        "id"         : "mood_sad",
        "name"       : "Somewhat Sad",
        "flags"      : ["mood"],
        "transient"  : true,
        "description": "Feeling down. Work efficiency is reduced.",
        "color"      : "#FF5722",
        "charSpans"  : [ {"sheet": "font", "id": 25} ],
        "modifiers"  : {"workEfficiency": 0.8}
    },
    {
        "id"         : "mood_depressed",
        "name"       : "Deeply Depressed",
        "flags"      : ["mood"],
        "transient"  : true,
        "description": "Severely depressed. Work efficiency is greatly reduced.",
        "color"      : "#D32F2F",
        "charSpans"  : [ {"sheet": "font", "id": 31} ],
        "modifiers"  : {"workEfficiency": 0.6}
    },
    {
        // MOOD: a full mental break. Stamped as a timed condition (rolled span) when a miserable pawn
        // fails its moral check; while it holds, the FSM forces the pawn into the Breakdown state and
        // refuses the draft (`fsmState` + the incapacitated flag, exactly like collapse). It clears on
        // its own when the timer runs out, and the pawn stands up with a wave of catharsis (mood_catharsis).
        "id"         : "mental_breakdown",
        "name"       : "Breaking Down",
        "flags"      : ["mood", "incapacitated"],
        "transient"  : true,
        "description": "Something has finally given way. Beyond reach and beyond orders, the mind turns inward until the worst of it passes.",
        "color"      : "#7E57C2",
        "floater"    : true,
        "charSpans"  : [ {"sheet": "font", "id": 31} ],
        // Priority just under collapse (100) — a body on the ground still reads first, but a breakdown
        // outranks every ordinary state tell.
        "priority"   : 90,
        // Default coping substate; the onset overrides it with the rolled kind (Crying/Hiding/Panicking).
        "fsmState"   : "Crying",
        "modifiers"  : {}
    },
    // ── On-hit combat effects (inflicted by creature natural weapons) ─────────
    // Timed transient debuffs applied when a venom/feeding/screech/tongue natural weapon lands (see
    // the weapon's `onHitEffect` in items.jsonc). Stored via conditionTimers like knockdown, so they
    // decrement each tick and auto-clear. Trigger chance is reduced by the named resistance stat.
    {
        "id": "envenomed",
        "audio": "envenomed",
        "name": "Envenomed",
        "flags": ["combat", "poison"],
        "transient": true,
        "description": "Venom courses through the blood, nauseous, weak and shaking. Strength, dexterity and endurance all fail until it passes. Onset chance is reduced by poison resistance (CON × blood filtration).",
        "color": "#7CB342",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 21} ],
        // TRAIT-SYSTEM-V2 §5: the venom churns the stomach — while envenomed, a small per-second chance
        // to also turn nauseous (a NEW secondary the graph enables; nausea decays on its own).
        "triggers": [ {"to": "nausea", "chance": 0.015, "durationHours": 1.5} ],
        "modifiers": {
            "strength"      : 0.6,
            "dexterity"     : 0.6,
            "constitution"  : 0.7,
            "workEfficiency": 0.7,
            "moveSpeed"     : 0.8,
            "fatigueRate"   : 1.3
        }
    },
    // (RETIRED — TRAIT-LIBRARY-EXPANSION §3b: `bloodletting` is now a PHYSICAL bleed-wound. A
    // bleed-weapon (item `bleedWound` chance) marks the inflicted injury `noSelfClot`: it bleeds at
    // full rate until a caretaker dresses it — a real wound in the health panel, not a timed pill.)
    {
        "id": "disoriented",
        "audio": "disoriented",
        "name": "Disoriented",
        "flags": ["combat", "mental"],
        "transient": true,
        "description": "Reeling from a piercing screech, senses scrambled, slow to act and easy to land a blow on. Perception and dexterity scatter. Onset chance is reduced by mental resistance (INT).",
        "color": "#AB47BC",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        "modifiers": {"perception": 0.4, "dexterity": 0.6, "intelligence": 0.7, "workEfficiency": 0.7, "moveSpeed": 0.9}
    },
    {
        "id": "ensnared",
        "audio": "ensnared",
        "name": "Ensnared",
        "flags": ["combat", "control"],
        "transient": true,
        "description": "Caught fast by a sticky tongue, rooted in place and wide open until torn free. Onset chance is reduced by blunt resistance (CON/STR, wrenching free).",
        "color": "#8D6E63",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.4, "moveSpeed": 0.0}
    },
    // ── Weapon-signature on-hit effects (crafted-weapon `onHitEffect`) ────────
    // Same timed-transient machinery as the creature effects above, but inflicted by HELD weapons: a
    // spear shoves (knockback → the displacement is CODE in Combat.ts; this is its recovery-of-footing
    // marker), a devastating warhammer rattles the skull, a great cleaver maims the legs. Onset chance
    // is reduced by the matching resistance stat named on the weapon's onHitEffect.
    {
        "id": "staggered",
        "audio": "knockdown",
        "name": "Staggered",
        "flags": ["combat", "control"],
        "transient": true,
        "description": "Shoved back off balance by a spear thrust, reeling for footing, slow and open for a beat before recovering.",
        "color": "#E08840",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 15} ],
        "modifiers": {"dexterity": 0.85, "moveSpeed": 0.9}
    },
    {
        "id": "concussed",
        "audio": "knockdown",
        "name": "Concussed",
        "flags": ["combat", "mental"],
        "transient": true,
        "description": "Skull rung by a crushing hammer blow, vision swims and the head won't clear. Perception, dexterity and wakefulness all crater; a devastating follow-up is easy to land.",
        "color": "#9C6AC0",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 19} ],
        "modifiers": {"perception": 0.5, "dexterity": 0.6, "consciousness": 0.7, "workEfficiency": 0.5}
    },
    {
        "id": "hamstrung",
        "audio": "bloodletting",
        "name": "Hamstrung",
        "flags": ["combat", "injury"],
        "transient": true,
        "description": "A deep cut to the leg, the tendon severed, the footing gone. Barely able to move and slow to react until it mends.",
        "color": "#B5502E",
        "floater": true,
        "charSpans": [ {"sheet": "font", "id": 3} ],
        "modifiers": {"moveSpeed": 0.4, "dexterity": 0.75}
    },
    // ── Racial trait conditions (ADR-023 · ADR-028) ──────────────────────────
    // The legible pill for a rare/epic/legendary body trait — pushed by syncTransientConditions for
    // every trait carrying the id as `selfCondition`, and the HUB for its combat capability:
    // `grantsNaturalWeapon` (item ids) / `grantsNaturalArmor` (0–100 defense). Natural ARMOR is gear
    // (TRAIT-SYSTEM-V2 §3): `carryPenalty` (0–1) eats that FRACTION of the pawn's carry CAPACITY (worn
    // always → less spare load; never added kg, which could encumber a weak pawn while bare) and `mode`
    // decides how it meets worn armour — "stack" ADDS to the worn soak (armor under the clothes),
    // "replace" competes best-of as the blocked slot's layer.
    // `photosynthesis`/`light_sensitive` are ENVIRONMENT-GATED (pushed only while active) and
    // `burning` is a combat DoT applied via onHitEffect (conditionTimers).
    {
        "id"         : "feathered",
        "name"       : "Feathered",
        "flags"      : ["racial", "passive"],
        "transient"  : true,
        "description": "A covering of fine down, natural insulation that holds warmth against the cold.",
        "color"      : "#C9B48A",
        "charSpans"  : [ {"sheet": "items", "id": 145} ],
        "modifiers"  : {}
    },
    {
        "id"         : "gilled",
        "name"       : "Gilled",
        "flags"      : ["racial", "passive"],
        "transient"  : true,
        "description": "Slitted gills at the throat, breathes water as easily as air.",
        "color"      : "#4FC3C7",
