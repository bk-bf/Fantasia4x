                "color"      : "#C04030",
                "modifiers"  : {
                    "dexterity"     : 0.45,
                    "strength"      : 0.75,
                    "moveSpeed"     : 0.6 ,
                    "workEfficiency": 0.6 ,
                    "fatigueRate"   : 1.6
                }
            }
        ]
    },
    {
        "id": "overmatched",
        "name": "Overmatched",
        "flags": ["physical", "weapon"],
        "description": "Straining to control a weapon heavier than the body can master — a crude orc slab in a mortal grip. Swings go wide, blows land soft, and the effort drains fast; only raw muscle tames such a thing. Severity = how far the wielder's strength falls short of the weapon's (driven directly, not over time).",
        "lethalSeverity": 99,
        "stages": [
            {
                "label"      : "unwieldy",
                "minSeverity": 0.0,
