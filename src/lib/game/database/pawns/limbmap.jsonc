        "anteriorMedianRightEye" : {"size": 4, "bleedRatio": 0.005, "hitWeight": 0.05, "isPaired": true, "containedIn": "cephalothorax", "armor": 0.1, "grants": {"nightVision": 0.15}},
        "anteriorLateralLeftEye" : {"size": 4, "bleedRatio": 0.005, "hitWeight": 0.05, "isPaired": true, "containedIn": "cephalothorax", "armor": 0.1, "grants": {"nightVision": 0.15}},
        "anteriorLateralRightEye": {"size": 4, "bleedRatio": 0.005, "hitWeight": 0.05, "isPaired": true, "containedIn": "cephalothorax", "armor": 0.1, "grants": {"nightVision": 0.15}},
