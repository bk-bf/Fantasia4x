        "rightVenomGland"        : {"size": 12, "bleedRatio": 0.03, "hitWeight": 0, "isPaired": true, "containedIn": "cephalothorax", "weapons": ["venom_bite", "greater-venom-bite"]},
        "suckingStomach"         : {"size": 12, "bleedRatio": 0.03, "hitWeight": 0, "containedIn": "cephalothorax"},
        // grants (TRAITS §0): each extra eye adds night vision (summed live over living eyes — lose an
