// limbmap.jsonc — body plans (anatomies) per creature CATEGORY, so a wolf carries paws + a tail, not a
// humanoid's fingers/toes. Structure:
//
//   "shared.parts" — the universal catalog: internal organs + the common head/torso outer parts every
//       standard-bodied creature has. Defined ONCE here so plans don't repeat them.
//
//   "plans" — one self-contained block PER body plan, co-locating its OWN parts with its limb layout:
//       "parts"  — parts unique to this plan (humanoid fingers, quadruped paws, avian wings, hooves…).
//       "limbs"  — limbId → [partId, …]: the limbs this plan has and which parts hang off each.
//     Every plan's parts (+ shared) merge into ONE global PART_DEF_MAP, so a plan's `limbs` may reuse
//     parts declared by another plan (quadruped_hooved reuses quadruped's leg segments + tail).
//
//   Part fields: size (default HP at bodyScale 1.0 — per-creature maxHp = round(size×bodyScale), set at
//   spawn; the map never stores final HP and does NOT drive the blood pool), bleedRatio, hitWeight
//   (0 = internal organ/skeleton, never rolled), isVital, isPaired, containedIn, skeleton (the ONE bone
//   type — see below), critical (destroying it = instant death; reserved for a vital CORE like the
//   amorphous essence — a BONE is never critical). The core organs (brain/heart/lungs) must exist on every plan so the
//   capacity model (consciousness/breathing/blood) resolves; the `moving` capacity reads "leg" limbs,
//   `manipulation` reads "arm" limbs.
//
//   SKELETON model (ONE bone type — there is no `bone: true` self-bone anywhere): EVERY bony part is a
//   soft-tissue OUTER part (hitWeight > 0; takes cut/puncture/crush, mounts natural weapons + armour)
//   WRAPPING a `skeleton: true` bone part (hitWeight 0 → never struck directly; takes ONLY fractures).
//   The bone is `containedIn` its flesh part; a hit on the flesh routes its fracture roll to the bone
//   beneath (see Combat `skeletonPartOf`). Breaking the bone cripples without severing; a severed flesh
//   part takes its bone with it. The chest→ribcage pair is the template, and EVERY bone carries its real
//   anatomical name (no `<region>Bone`): head→skull, jaw→mandible, snout→rostrum, forearm→ulna, hand→
//   metacarpus, upperLeg→femur, wing→humerus/carpometacarpus, bird leg→tibiotarsus/tarsometatarsus, tail→
//   caudalVertebrae, snake body→fore/mid/hindVertebrae. The FLESH container holds the vital organ + kills
//   when torn apart; the BONE only cripples when broken. (No internal bone for things that HAVE none: snake
//   fangs are TEETH and arthropods are EXOSKELETAL — chitin is the hittable structure, no skeleton child.)
//
// Add `limbMap: "<plan>"` to a creature in creatures.jsonc; pawns default to "humanoid".
{
  "shared": {
    "parts": {
      // ── Internal organs (hitWeight 0 — shielded, never rolled directly) ───────────────────────────
      "brain"       : {"size": 30, "bleedRatio": 0.05, "hitWeight": 0, "isVital": true, "containedIn": "head"},
      "heart"       : {"size": 20, "bleedRatio": 0.08, "hitWeight": 0, "isVital": true, "containedIn": "chest"},
      "leftLung"    : {"size": 30, "bleedRatio": 0.06, "hitWeight": 0, "isPaired": true, "containedIn": "chest"},
      "rightLung"   : {"size": 30, "bleedRatio": 0.06, "hitWeight": 0, "isPaired": true, "containedIn": "chest"},
      "liver"       : {"size": 25, "bleedRatio": 0.05, "hitWeight": 0, "containedIn": "abdomen"},
      "stomach"     : {"size": 20, "bleedRatio": 0.03, "hitWeight": 0, "containedIn": "abdomen"},
      "leftKidney"  : {"size": 15, "bleedRatio": 0.02, "hitWeight": 0, "isPaired": true, "containedIn": "abdomen"},
      "rightKidney" : {"size": 15, "bleedRatio": 0.02, "hitWeight": 0, "isPaired": true, "containedIn": "abdomen"},
      "spine"       : {"size": 40, "bleedRatio": 0.04, "hitWeight": 0, "containedIn": "chest"},
      // ── Common head + torso outer parts ──────────────────────────────────────────────────────────
      // SAME flesh+skeleton split as the torso (chest wraps ribcage): the FLESH outer is the region — `head`
      // wraps the `skull`, `jaw` wraps the `jawBone` (mandible) — and takes the cut/crush, mounts the natural
      // weapons + armour, and HOLDS the vital organ (brain in the head). The bone is the hidden `skeleton`
      // beneath: fracture-only, never struck directly. Tearing the FLESH apart (head/chest → limb gone) takes
      // the organ and kills; breaking the BONE alone only cripples — a bone is never instant death.
      "head"        : {"size": 45, "bleedRatio": 0.04, "hitWeight": 13, "weapons": ["headbutt", "antler", "goring-horns", "great-horns", "flame-breath", "ember-breath", "dragonfire"], "armor": 0.8},
      "skull"       : {"size": 45, "bleedRatio": 0.0, "hitWeight": 0, "skeleton": true, "containedIn": "head"},
      "jaw"         : {"size": 15, "bleedRatio": 0.02, "hitWeight": 2, "weapons": ["bite", "tusk", "tongue", "screech", "goring-fangs", "sabre-fangs", "boar_tusk", "great-tusks", "serpent-fangs", "deathly-fangs", "bloodsucking-fangs"], "armor": 0.5},
      "mandible"     : {"size": 15, "bleedRatio": 0.0, "hitWeight": 0, "skeleton": true, "containedIn": "jaw"},
      "nose"        : {"size": 5, "bleedRatio": 0.01, "hitWeight": 0.4, "armor": 0.3},
      // Facial soft-tissue features (no own skeleton — cartilage/skin over the skull, like the nose): a
      // head is more than nose+eyes+jaw. Hittable + scarrable; forehead is broad + midline, cheeks paired.
      "forehead"    : {"size": 12, "bleedRatio": 0.02, "hitWeight": 0.5, "armor": 0.4},
      "leftCheek"   : {"size": 8, "bleedRatio": 0.015, "hitWeight": 0.3, "isPaired": true, "armor": 0.3},
      "rightCheek"  : {"size": 8, "bleedRatio": 0.015, "hitWeight": 0.3, "isPaired": true, "armor": 0.3},
      "snout"       : {"size": 20, "bleedRatio": 0.02, "hitWeight": 3, "weapons": ["tusk", "bite"], "armor": 0.7},
      "rostrum"   : {"size": 20, "bleedRatio": 0.0, "hitWeight": 0, "skeleton": true, "containedIn": "snout"},
      "leftEye"     : {"size": 10, "bleedRatio": 0.01, "hitWeight": 0.2, "isPaired": true, "armor": 0.1},
      "rightEye"    : {"size": 10, "bleedRatio": 0.01, "hitWeight": 0.2, "isPaired": true, "armor": 0.1},
      "leftEar"     : {"size": 10, "bleedRatio": 0.005, "hitWeight": 0.2, "isPaired": true, "armor": 0.2},
      "rightEar"    : {"size": 10, "bleedRatio": 0.005, "hitWeight": 0.2, "isPaired": true, "armor": 0.2},
      // The throat — soft (armor 0) and bleeds hard (carotid/trachea); the target a gorget guards.
      // Shared by EVERY standard-bodied plan (not just humanoids) — the classic "gap" on an armoured
      // beast: a wolf's throat is as bare as a man's (CREATURE-COMBAT-OVERHAUL §1a).
      "neck"        : {"size": 20, "bleedRatio": 0.06, "hitWeight": 2, "armor": 0},
      // The carotid — a real organ INSIDE the neck (hitWeight 0, found only by the organ-penetration
      // roll on a neck hit). Not vital: nicking it doesn't kill outright, it opens a hard bleed-out
      // (small size → wounds hit high severity fast; big bleedRatio → they gush). `artery` → the wound
      // is UNCLOTTABLE (bleeds until dressed), so a slit throat is a slow kill, not an instant one.
      "carotidArtery": {"size": 8, "bleedRatio": 0.12, "hitWeight": 0, "containedIn": "neck", "artery": true},
      // The chest is the SOFT outer wall of the thorax (pecs/skin) wrapping the ribcage — it takes
      // cut/puncture/crush like any flesh, but it is NOT bone, so it never fractures. The skeleton beneath
      // it is the `ribcage` (below): heavy blows crack THAT, not the wall. (See Combat's fracture routing.)
      "chest"       : {"size": 80, "bleedRatio": 0.12, "hitWeight": 32, "weapons": ["charge", "slam"], "armor": 1},
      "abdomen"     : {"size": 70, "bleedRatio": 0.1, "hitWeight": 24, "weapons": ["web-shot"], "armor": 0.5},
      // The ribcage — the thorax SKELETON. Internal (hitWeight 0 → never struck directly), `skeleton: true`
      // so it can ONLY take fractures (no cut/puncture/crush). A heavy hit to the `chest` routes its fracture
      // roll here; size matches the chest so the break threshold is unchanged. Severed with the chest.
      "ribcage"     : {"size": 80, "bleedRatio": 0.0, "hitWeight": 0, "skeleton": true, "containedIn": "chest"}
    }
  },
  "plans": {
    "humanoid": {
      "// note": "Each limb SEGMENT is soft tissue (cut/puncture/crush) wrapping its named bone (scapula/humerus/ulna/metacarpus, ilium/femur/tibia/metatarsus; hitWeight 0, fracture-only) — a hit on the flesh routes its fracture to the bone within. Same model as chest→ribcage.",
      "parts": {
        // The groin — the femoral weak point below armour coverage (CREATURE-COMBAT-OVERHAUL §1a):
        // near-bare (armor 0.1), bleeds hard, and holds the femoral artery for the penetration roll.
        "groin"            : {"size": 15, "bleedRatio": 0.05, "hitWeight": 1.5, "armor": 0.1},
        "femoralArtery"    : {"size": 8, "bleedRatio": 0.1, "hitWeight": 0, "containedIn": "groin", "artery": true},
        "leftShoulder"     : {"size": 40, "bleedRatio": 0.03, "hitWeight": 1, "isPaired": true, "armor": 0.7},
        "leftScapula" : {"size": 40, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftShoulder"},
        "leftUpperArm"     : {"size": 45, "bleedRatio": 0.05, "hitWeight": 2, "isPaired": true, "armor": 0.6},
        "leftHumerus" : {"size": 45, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftUpperArm"},
        "leftForearm"      : {"size": 35, "bleedRatio": 0.04, "hitWeight": 1.5, "isPaired": true, "armor": 0.5},
        // TODO(anatomy): the forearm is really two parallel bones (radius + ulna) and the lower leg two
        // (tibia + fibula). We model each segment as its single dominant bone (ulna / tibia) because the
        // engine binds one bone per flesh segment (skeletonPartOf). Splitting them — so one can break while
        // the other holds — needs that 1:1 routing relaxed; applies to the quadruped/avian analogues too.
        "leftUlna"  : {"size": 35, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftForearm"},
        "leftHand"         : {"size": 30, "bleedRatio": 0.05, "hitWeight": 1, "isPaired": true, "weapons": ["fists", "claw", "rending-claws", "moonlit-claws", "dragon-claws", "blunt-claws", "ripping-talons", "crusher-claw", "shock-strike", "chill-strike"], "armor": 0.4},
        "leftMetacarpus"     : {"size": 30, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftHand"},
        "leftThumb"        : {"size": 5, "bleedRatio": 0.005, "hitWeight": 0.1, "isPaired": true, "containedIn": "leftHand", "armor": 0.5},
        "leftIndexFinger"  : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "leftHand", "armor": 0.2},
        "leftMiddleFinger" : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "leftHand", "armor": 0.2},
        "leftRingFinger"   : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "leftHand", "armor": 0.2},
        "leftLittleFinger" : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "leftHand", "armor": 0.2},
        "rightShoulder"    : {"size": 40, "bleedRatio": 0.03, "hitWeight": 1, "isPaired": true, "armor": 0.7},
        "rightScapula": {"size": 40, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "rightShoulder"},
        "rightUpperArm"    : {"size": 45, "bleedRatio": 0.05, "hitWeight": 2, "isPaired": true, "armor": 0.6},
        "rightHumerus": {"size": 45, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "rightUpperArm"},
        "rightForearm"     : {"size": 35, "bleedRatio": 0.04, "hitWeight": 1.5, "isPaired": true, "armor": 0.5},
        "rightUlna" : {"size": 35, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "rightForearm"},
        "rightHand"        : {"size": 30, "bleedRatio": 0.05, "hitWeight": 1, "isPaired": true, "weapons": ["fists", "claw", "rending-claws", "moonlit-claws", "dragon-claws", "blunt-claws", "ripping-talons", "crusher-claw", "shock-strike", "chill-strike"], "armor": 0.4},
        "rightMetacarpus"    : {"size": 30, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "rightHand"},
        "rightThumb"       : {"size": 5, "bleedRatio": 0.005, "hitWeight": 0.1, "isPaired": true, "containedIn": "rightHand", "armor": 0.5},
        "rightIndexFinger" : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "rightHand", "armor": 0.2},
        "rightMiddleFinger": {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "rightHand", "armor": 0.2},
        "rightRingFinger"  : {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "rightHand", "armor": 0.2},
        "rightLittleFinger": {"size": 3, "bleedRatio": 0.003, "hitWeight": 0.1, "isPaired": true, "containedIn": "rightHand", "armor": 0.2},
        "leftHip"          : {"size": 50, "bleedRatio": 0.04, "hitWeight": 1.5, "isPaired": true, "armor": 0.7},
        "leftIlium"      : {"size": 50, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftHip"},
        "leftUpperLeg"     : {"size": 60, "bleedRatio": 0.08, "hitWeight": 6, "isPaired": true, "armor": 0.6},
        "leftFemur" : {"size": 60, "bleedRatio": 0.0, "hitWeight": 0, "isPaired": true, "skeleton": true, "containedIn": "leftUpperLeg"},
