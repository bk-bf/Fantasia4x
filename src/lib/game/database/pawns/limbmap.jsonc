      "limbs": {
        "head": ["head", "skull", "forehead", "leftCheek", "rightCheek", "jaw", "mandible", "nose", "neck", "carotidArtery", "leftEye", "rightEye", "leftEar", "rightEar", "brain"],
        "torso": ["chest", "ribcage", "abdomen", "groin", "femoralArtery", "heart", "leftLung", "rightLung", "liver", "stomach", "leftKidney", "rightKidney", "spine"],
