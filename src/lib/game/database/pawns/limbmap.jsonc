        "legHindLeftA"           : {"size": 16, "bleedRatio": 0.015, "hitWeight": 1.2, "isPaired": true, "armor": 0.5},
        "legHindLeftB"           : {"size": 16, "bleedRatio": 0.015, "hitWeight": 1.2, "isPaired": true, "armor": 0.5},
        "legHindRightA"          : {"size": 16, "bleedRatio": 0.015, "hitWeight": 1.2, "isPaired": true, "armor": 0.5},
        "legHindRightB"          : {"size": 16, "bleedRatio": 0.015, "hitWeight": 1.2, "isPaired": true, "armor": 0.5},
        "synganglion"            : {"size": 18, "bleedRatio": 0.05, "hitWeight": 0, "isVital": true, "containedIn": "cephalothorax"},
