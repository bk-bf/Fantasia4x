        "hindBody"       : {"size": 55, "bleedRatio": 0.07, "hitWeight": 12, "armor": 0.7},
        "hindVertebrae"  : {"size": 55, "bleedRatio": 0.0, "hitWeight": 0, "skeleton": true, "containedIn": "hindBody"},
        "foreKidney"     : {"size": 14, "bleedRatio": 0.02, "hitWeight": 0, "containedIn": "midBody"},
