        "kind"         : "naturalGear",
        "stage"        : 3,
        "name"         : "Iron Skin",
        "description"  : "Metallic skin that sets hard as armor plate, a walking suit of plate, and rarer for it.",
        "flavorLine"   : "their skin sets hard as weathered stone, turning aside blows that would lay low softer folk",
        "naturalArmor": 18,
        "carryPenalty": 0.15,
        "effects"      : {}
    },
    {
        "id"           : "rending-claws",
        "scope"        : "cultural",
        "rarity"       : "rare",
        "kind"         : "naturalGear",
        "stage"        : 2,
        "evolvesTo"    : "ripping-talons",
        // LINEAGES: a beast/werewolf gateway — may roll standalone (lineageExclusive:false), seeding an
        // awakening meter toward EITHER bloodline; the deeds the pawn does decide which it turns into.
        "lineage"      : ["beast", "werewolf"],
        "lineageExclusive": false,
        "awakens"      : ["devour-raw-meat", "devour-carcass", "wild-kills", "moon-bathing", "cull-canines", "night-hunter"],
        "name"         : "Rending Claws",
        "description"  : "Curved claws for hands, devastating unarmed, but useless at a workbench.",
        "flavorLine"   : "in place of fingers they bear long, hooked claws that open flesh like cloth",
        "naturalWeapons": ["rending-claws"],
        // Stage 2: blocks gloves only — still clumsy enough to grip a weapon. Tools work from the
        // inventory, so mainHand stays free. Apex (stage 3) blocks the weapon hands, see ripping-talons.
        "blocksSlots"  : ["gloves"],
        // dexterityPenalty folds the retired `clawed` condition's DEX ×0.95 (clumsy claw-hands).
        "effects"      : { "dexterityPenalty": 1, "workSpeed": {"crafting": 0.75, "leatherworking": 0.8, "construction": 0.85} }
    },
