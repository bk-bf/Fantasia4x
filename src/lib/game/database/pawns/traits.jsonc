    // ═══════════════════════════════════════════════════════════════════════════
    // §3 · Staged natural gear — every weapon/armor line has 3 stages (S1 uncommon → S2 rare →
    // S3 epic), chained by `evolvesTo` + a `stage` flag (data only for now — a later age/ritual
    // system walks the chain). Existing traits (rending-claws, gore-horns, venomous, thick-fur,
    // scaled-hide/iron-skin, feathered) got stage flags and slot in as their line's rungs.
    // ═══════════════════════════════════════════════════════════════════════════
    {
        "id"           : "budding-claws",
        "scope"        : "cultural",
        "rarity"       : "uncommon",
        "kind"         : "naturalGear",
        "stage"        : 1,
        "name"         : "Budding Claws",
        "description"  : "Short hardened claw-nubs, a scraping unarmed strike, the seed of a claw line.",
        "flavorLine"   : "their fingertips end in hard little hooks",
        "naturalWeapons": ["blunt-claws"],
        "evolvesTo"    : "rending-claws",
        "effects"      : {}
    },
    {
        "id": "ripping-talons",
        "scope": "cultural",
        "rarity": "epic",
        "kind": "naturalGear",
        "stage": 3,
        "lineage": ["beast", "werewolf"],
        "name": "Ripping Talons",
        "description": "Great hooked talons in place of hands, devastating unarmed, hopeless at a bench, and the wounds they leave will not close unaided.",
        "flavorLine": "their hands are a raptor's killing tools",
        "naturalWeapons": ["ripping-talons"],
        // Stage 3 apex: the talons are too big to grip anything — no gloves, and no weapon/shield either.
        "blocksSlots": ["gloves", "mainHand", "offHand"],
        // dexterityPenalty folds the retired `taloned` condition's DEX ×0.92 (killing tools, not hands).
        "effects": { "dexterityPenalty": 1, "workSpeed": {"crafting": 0.7, "leatherworking": 0.75, "construction": 0.8} }
    },
