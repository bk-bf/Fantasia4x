        "stage"        : 1,
        "evolvesTo"    : "plumed-coat",
        "name"         : "Feathered",
        "description"  : "A covering of fine down, natural insulation against the cold.",
        "flavorLine"   : "a down of fine feathers softens their every movement",
        "selfCondition": "feathered",
        "effects": {}, "resistances": {"cold": 0.2}
    },
    {
        "id"           : "scaled-hide",
