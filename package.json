{
  "name": "fantasia4x",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "graph": "node tools/codegraph/extract.mjs && node tools/codegraph/build-html.mjs",
    "graph:serve": "node tools/codegraph/serve.mjs",
    "graph:check": "node tools/codegraph/extract.mjs && node tools/codegraph/check.mjs",
    "graph:snapshot": "node tools/codegraph/extract.mjs && node tools/codegraph/diff.mjs --save",
    "graph:diff": "node tools/codegraph/extract.mjs && node tools/codegraph/diff.mjs",
    "add:wasm": "cd spatial-core && ~/.cargo/bin/wasm-pack build --target web --out-dir ../src/lib/spatial-core-pkg"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.10.1",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.6",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "simplex-noise": "^4.0.3",
    "uuid": "^11.1.0"
  }
}
