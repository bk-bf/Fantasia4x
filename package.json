{
	"name": "fantasia4x",
	"private": true,
	"version": "0.1.119",
	"license": "AGPL-3.0-or-later",
	"description": "Fantasia4x — a turn-based 4X colony chronicle.",
	"author": "bk",
	"type": "module",
	"main": "electron/main.cjs",
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"electron": "electron .",
		"package": "electron-builder",
		"package:dir": "electron-builder --dir",
		"dist": "pnpm build && electron-builder",
		"test": "vitest run",
		"test:changed": "vitest run --changed",
		"test:related": "vitest related --run",
		"test:watch": "vitest",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"graph": "node ../codegraph/bin/codegraph.mjs extract Fantasia4x",
		"graph:serve": "cd ../codegraph && pnpm dev -- --port 5180 --strictPort",
		"graph:check": "node ../codegraph/bin/codegraph.mjs check Fantasia4x",
		"graph:snapshot": "node ../codegraph/bin/codegraph.mjs snapshot Fantasia4x",
		"graph:diff": "node ../codegraph/bin/codegraph.mjs diff Fantasia4x",
		"add:wasm": "cd spatial-core && ~/.cargo/bin/wasm-pack build --target web --out-dir ../src/lib/spatial-core-pkg",
		"add:wasm:sim": "cd sim-core && ~/.cargo/bin/wasm-pack build --target web --out-dir ../src/lib/sim-core-pkg",
		"test:sim-core": "cd sim-core && cargo test",
		"threat": "node scripts/threat-model.mjs",
		"threat:check": "node scripts/threat-model.mjs --check",
		"build:distance": "bash scripts/build-distance.sh",
		"hooks:install": "bash scripts/hooks/install.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.30.0",
		"@firefox-devtools/profiler-cli": "^0.2.1",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@types/howler": "^2.2.13",
		"@types/uuid": "^10.0.0",
		"@typescript-eslint/eslint-plugin": "^8.35.0",
		"@typescript-eslint/parser": "^8.35.0",
		"electron": "^42.4.0",
		"electron-builder": "^25.1.8",
		"eslint": "^9.30.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-svelte": "^3.10.1",
		"globals": "^16.2.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vite-plugin-wasm": "^3.6.0",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"howler": "^2.2.4",
		"simplex-noise": "^4.0.3",
		"uuid": "^11.1.0"
	}
}
