#!/usr/bin/env bash
# Fantasia4x pre-commit: refuse a commit once the tree has drifted BUILD_DISTANCE_MAX (default 100)
# commits past the last release build (last v* tag) — forcing a new release to be cut first.
#
# Bypass for a one-off: git commit --no-verify
# Tune the cap:        BUILD_DISTANCE_MAX=150 git commit ...   (or edit the script default)
#
# This is the tracked SOURCE of the hook. Install it into .git/hooks with:  pnpm hooks:install
ROOT="$(git rev-parse --show-toplevel)"
exec "$ROOT/scripts/build-distance.sh" --check
